---
import { Languages } from "../utils/consts";
import VerseReader from "./VerseReader.astro";
import "../styles/ArticleBody.css";

const { Content, data, availableLanguages, verses = [], availableScripts = ["devanagari"] } = Astro.props;
const langOptions = Languages.filter((item) =>
  (availableLanguages || []).includes(item.label)
);

// New scripture pages carry structured `verses` (Devanagari/IAST + translations)
// and render via <VerseReader>, which owns its own script/translation toggles;
// any markdown body they also carry (prose translations, notes) renders below
// the verses. Legacy prose / vidhi pages have no `verses` and keep the
// markdown-body path with the older per-language show/hide switcher below.
const hasVerses = Array.isArray(verses) && verses.length > 0;

// PDF export modal: mirrors the on-page reading toggles (VerseReader's script
// switch, either reader's translation switch) so the dialog offers exactly
// what the page can render. Shown only when there is a real choice to make;
// otherwise the toolbar button downloads directly.
const PDF_SCRIPTS = [
  { id: "devanagari", name: "Devanagari", symbol: "अ" },
  { id: "iast", name: "IAST", symbol: "Ā" },
];
const hasIast = hasVerses && verses.some((v: any) => v.iast);
const pdfScriptOptions = hasVerses
  ? PDF_SCRIPTS.filter(
      (s) => (availableScripts || []).includes(s.id) && (s.id !== "iast" || hasIast)
    )
  : [];
const pdfNeedsModal = pdfScriptOptions.length > 1 || langOptions.length > 1;
---

<script
  is:inline
  define:vars={{ data: data, availableLanguages: hasVerses ? [] : availableLanguages }}
>
  const selectedClasses = "reader-lang--active";
  const langButtons = availableLanguages.map((lang) => `lang-${lang}`);

  const removeSelectedFromAll = () => {
    langButtons.forEach((id) => {
      document.getElementById(id).classList.remove(...selectedClasses.split(" "));
    });
  };

  const onPageLoad = () => {
    if (availableLanguages.length > 0) {
      removeSelectedFromAll();
      const firstLangId = `lang-${availableLanguages[0]}`;
      document.getElementById(firstLangId).classList.add(...selectedClasses.split(" "));

      document.querySelectorAll(`.${availableLanguages[0]}-translation`).forEach((element) => {
        element.style.display = "block";
      });

      const otherLanguages = availableLanguages.filter((item) => item != availableLanguages[0]);
      otherLanguages.forEach((lang) => {
        document.querySelectorAll(`.${lang}-translation`).forEach((element) => {
          element.style.display = "none";
        });
      });
    }

    langButtons.forEach((buttonId, languageId) => {
      const language = availableLanguages[languageId];
      document.getElementById(buttonId).onclick = () => {
        removeSelectedFromAll();
        document.getElementById(buttonId).classList.add(...selectedClasses.split(" "));
        document.querySelectorAll(`.${language}-translation`).forEach((element) => {
          element.style.display = "block";
        });
        const otherLanguages = availableLanguages.filter((item) => item != language);
        otherLanguages.forEach((lang) => {
          document.querySelectorAll(`.${lang}-translation`).forEach((element) => {
            element.style.display = "none";
          });
        });
      };
    });
  };

  window.addEventListener("load", () => {
    onPageLoad();
  });
</script>

<div class="w-full relative">
  <style>
    .parchment-paper {
      position: relative;
      background: #fffef0;
      box-shadow: 
        2px 3px 20px rgba(0, 0, 0, 0.5),
        0 0 100px rgba(139, 89, 34, 0.4) inset;
      padding: 2rem 1.25rem;
      margin: 0;
      width: 100%;
      min-height: 100vh;
    }

    /* Apply wavy edges only to a border element, not the content */
    .parchment-paper::after {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: transparent;
      border: 1px solid rgba(139, 89, 34, 0.3);
      filter: url(#wavy-edges);
      pointer-events: none;
      z-index: 0;
    }

    @media (min-width: 640px) {
      .parchment-paper {
        padding: 2.5rem 2rem;
      }
    }

    @media (min-width: 768px) {
      .parchment-paper {
        padding: 3rem 3rem;
      }
    }

    @media (min-width: 1024px) {
      .parchment-paper {
        padding: 4rem 5rem;
      }
    }

    .parchment-paper::before {
      content: "";
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-image: 
        radial-gradient(circle at 20% 30%, rgba(139, 89, 34, 0.06) 0%, transparent 50%),
        radial-gradient(circle at 80% 70%, rgba(139, 89, 34, 0.06) 0%, transparent 50%),
        radial-gradient(circle at 40% 80%, rgba(139, 89, 34, 0.04) 0%, transparent 40%);
      pointer-events: none;
      z-index: 0;
    }

    #docBody {
      position: relative;
      z-index: 1;
      max-width: 1200px;
      margin: 0 auto;
      --reader-scale: 1;
    }

    #docBody, #docBody * {
      color: #2d1810 !important;
      text-rendering: optimizeLegibility !important;
      -webkit-font-smoothing: antialiased !important;
    }

    #docBody :global(h1), #docBody :global(h2), #docBody :global(h3), #docBody :global(h4) {
      color: #8b4513 !important;
      margin-top: 1.75rem !important;
      margin-bottom: 1rem !important;
      font-weight: 700 !important;
      text-align: center !important;
    }

    @media (min-width: 768px) {
      #docBody :global(h1), #docBody :global(h2), #docBody :global(h3), #docBody :global(h4) {
        margin-top: 2.5rem !important;
        margin-bottom: 1.5rem !important;
      }
    }

    #docBody :global(h1) {
      font-size: calc(1.625rem * var(--reader-scale, 1)) !important;
      border-bottom: 2px double rgba(139, 69, 19, 0.5) !important;
      padding-bottom: 0.625rem !important;
    }

    @media (min-width: 768px) {
      #docBody :global(h1) {
        font-size: calc(2.25rem * var(--reader-scale, 1)) !important;
        border-bottom: 3px double rgba(139, 69, 19, 0.5) !important;
        padding-bottom: 1rem !important;
      }
    }

    #docBody :global(h2) {
      font-size: calc(1.375rem * var(--reader-scale, 1)) !important;
      border-bottom: 2px solid rgba(139, 69, 19, 0.3) !important;
      padding-bottom: 0.5rem !important;
    }

    @media (min-width: 768px) {
      #docBody :global(h2) {
        font-size: calc(2rem * var(--reader-scale, 1)) !important;
        padding-bottom: 0.75rem !important;
      }
    }

    #docBody :global(p) {
      color: #2d1810 !important;
      line-height: 1.85rem !important;
      margin-bottom: 1.125rem !important;
      font-size: calc(0.9375rem * var(--reader-scale, 1)) !important;
      text-align: left !important;
    }

    @media (min-width: 640px) {
      #docBody :global(p) {
        line-height: 2rem !important;
        font-size: calc(1rem * var(--reader-scale, 1)) !important;
        text-align: justify !important;
      }
    }

    @media (min-width: 768px) {
      #docBody :global(p) {
        line-height: 2.2rem !important;
        margin-bottom: 1.5rem !important;
        font-size: calc(1.05rem * var(--reader-scale, 1)) !important;
      }
    }

    #docBody :global(.noto-sans-text), #docBody.noto-sans-text, #docBody.noto-sans-text * {
      font-size: calc(1.0625rem * var(--reader-scale, 1)) !important;
      line-height: 2.125rem !important;
      color: #1a0d08 !important;
      font-weight: 500 !important;
    }

    @media (min-width: 640px) {
      #docBody :global(.noto-sans-text), #docBody.noto-sans-text, #docBody.noto-sans-text * {
        font-size: calc(1.1875rem * var(--reader-scale, 1)) !important;
        line-height: 2.375rem !important;
      }
    }

    @media (min-width: 768px) {
      #docBody :global(.noto-sans-text), #docBody.noto-sans-text, #docBody.noto-sans-text * {
        font-size: calc(1.25rem * var(--reader-scale, 1)) !important;
        line-height: 2.5rem !important;
      }
    }

    /* Text-only (prose / vidhi) pages are authored mostly in Devanagari with
       some English. Structured verse pages set their own script font in
       VerseReader, so this is scoped to the non-verse (.docbody--prose) path.
       --font-devanagari falls back to Noto Sans for the interspersed English. */
    #docBody.docbody--prose,
    #docBody.docbody--prose :global(*) {
      font-family: var(--font-devanagari) !important;
    }

    #docBody :global(strong) {
      color: #6b2c0f !important;
      font-weight: 700 !important;
    }

    #docBody :global(blockquote) {
      border-left: 3px solid #8b4513 !important;
      background: rgba(139, 69, 19, 0.08) !important;
      padding: 1rem 1.25rem !important;
      margin: 1.5rem 0 !important;
      border-radius: 4px !important;
      font-size: calc(0.9rem * var(--reader-scale, 1)) !important;
    }

    @media (min-width: 768px) {
      #docBody :global(blockquote) {
        border-left: 5px solid #8b4513 !important;
        padding: 2rem 2.5rem !important;
        margin: 2.5rem 0 !important;
        font-size: calc(1rem * var(--reader-scale, 1)) !important;
      }
    }

    #docBody :global(ul), #docBody :global(ol) {
      padding-left: 1.5rem !important;
      margin: 1.25rem 0 !important;
    }

    @media (min-width: 768px) {
      #docBody :global(ul), #docBody :global(ol) {
        padding-left: 2.5rem !important;
        margin: 2rem 0 !important;
      }
    }

    #docBody :global(li) {
      margin-bottom: 0.875rem !important;
      line-height: 2rem !important;
      font-size: calc(0.9375rem * var(--reader-scale, 1)) !important;
    }

    @media (min-width: 640px) {
      #docBody :global(li) {
        margin-bottom: 1rem !important;
        line-height: 2.25rem !important;
        font-size: calc(1rem * var(--reader-scale, 1)) !important;
      }
    }

    @media (min-width: 768px) {
      #docBody :global(li) {
        margin-bottom: 1.25rem !important;
        line-height: 2.5rem !important;
        font-size: calc(1.05rem * var(--reader-scale, 1)) !important;
      }
    }

    #docBody :global(a) {
      color: #a0522d !important;
      border-bottom: 1px dotted #a0522d !important;
      word-break: break-word !important;
    }

    #docBody
    :global(.sanskrit-shlok),
    :global(.devanagari-translation), #docBody :global(.english-translation), #docBody :global(.hindi-translation) {
      animation: fadeIn 0.5s ease-in-out !important;
      padding: 0.4rem 0 !important;
    }

    @keyframes fadeIn {
      from { opacity: 0; transform: translateY(-15px); }
      to { opacity: 1; transform: translateY(0); }
    }
  </style>

  <svg style="position: absolute; width: 0; height: 0;">
    <filter id="wavy-edges" x="-50%" y="-50%" width="200%" height="200%">
      <feTurbulence type="fractalNoise" baseFrequency="0.01" numOctaves="4" result="noise" seed="2" />
      <feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G" />
    </filter>
  </svg>

  

  <div class="reader-toolbar" role="toolbar" aria-label="Reading controls">
    <div class="reader-toolbar__group">
      <span class="reader-toolbar__label">Text Size</span>
      <div class="reader-size">
        <button type="button" class="reader-size__btn" id="font-decrease" aria-label="Decrease text size">−</button>
        <span class="reader-size__value" id="font-percent" aria-live="polite">100%</span>
        <button type="button" class="reader-size__btn" id="font-increase" aria-label="Increase text size">+</button>
        <button type="button" class="reader-size__btn reader-size__btn--reset" id="font-reset" aria-label="Reset text size">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"></path><path d="M3 3v5h5"></path></svg>
        </button>
      </div>
    </div>

    <div class="reader-toolbar__group reader-toolbar__group--actions">
      <button type="button" class="reader-action" id="download-pdf-btn" aria-label="Download as PDF">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
        <span>Download PDF</span>
      </button>
      <button type="button" class="reader-action" id="share-btn" aria-label="Share this page">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="18" cy="5" r="3"></circle><circle cx="6" cy="12" r="3"></circle><circle cx="18" cy="19" r="3"></circle><line x1="8.59" x2="15.42" y1="13.51" y2="17.49"></line><line x1="15.41" x2="8.59" y1="6.51" y2="10.49"></line></svg>
        <span class="reader-action__label" id="share-label">Share</span>
      </button>
    </div>
  </div>

  {pdfNeedsModal && (
    <div class="pdf-modal" id="pdf-modal" hidden>
      <div class="pdf-modal__backdrop" data-pdf-close></div>
      <div class="pdf-modal__dialog" role="dialog" aria-modal="true" aria-labelledby="pdf-modal-title">
        <div class="pdf-modal__header">
          <h3 class="pdf-modal__title" id="pdf-modal-title">Download PDF</h3>
          <button type="button" class="pdf-modal__close" data-pdf-close aria-label="Close">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
        {/* <p class="pdf-modal__hint">Choose what goes into the PDF.</p> */}

        {pdfScriptOptions.length > 1 && (
          <div class="pdf-modal__group" role="group" aria-label="Script">
            <span class="pdf-modal__label">Script</span>
            <div class="pdf-modal__options" data-role="script">
              {pdfScriptOptions.map((s) => (
                <button type="button" class="pdf-opt" data-value={s.id} aria-pressed="false">
                  <span class="pdf-opt__symbol" aria-hidden="true">{s.symbol}</span>
                  <span class="pdf-opt__name">{s.name}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        {langOptions.length > 0 && (
          <div class="pdf-modal__group" role="group" aria-label="Translation language">
            <span class="pdf-modal__label">Translation</span>
            <div class="pdf-modal__options" data-role="lang">
              {langOptions.map((l) => (
                <button type="button" class="pdf-opt" data-value={l.label} aria-pressed="false">
                  <span class="pdf-opt__symbol" aria-hidden="true">{l.symbol}</span>
                  <span class="pdf-opt__name">{l.label}</span>
                </button>
              ))}
            </div>
          </div>
        )}

        <button type="button" class="reader-action pdf-modal__download" id="pdf-modal-download">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" x2="12" y1="15" y2="3"></line></svg>
          <span>Download PDF</span>
        </button>
      </div>
    </div>
  )}

  <div class="parchment-paper">
    {!hasVerses && langOptions.length > 0 && (
      <div class="reader-translate" role="group" aria-label="Translation language">
        <span class="reader-translate__label">Translation</span>
        <div class="reader-langs">
          {langOptions.map((item) => (
            <button
              type="button"
              id={`lang-${item.label}`}
              class="reader-lang"
              title={`Show ${item.label} translation`}
              aria-label={`Show ${item.label} translation`}
            >
              <span class="reader-lang__symbol">{item.symbol}</span>
              <span class="reader-lang__name">{item.label}</span>
            </button>
          ))}
        </div>
      </div>
    )}
    <div
      id="docBody"
      class:list={["noto-sans-text prose prose-lg max-w-none", { "docbody--prose": !hasVerses }]}
    >
      {hasVerses ? (
        <>
          <VerseReader
            verses={verses}
            availableScripts={availableScripts}
            availableLanguages={availableLanguages}
          />
          {/* Verse pages may still carry a markdown body (e.g. prose
              translations or notes) - render it below the verses. */}
          <Content />
        </>
      ) : (
        <Content />
      )}
    </div>
  </div>
</div>

<style>
  .reader-toolbar {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-5);
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-3) var(--space-4);
    margin-bottom: var(--space-5);
  }

  .reader-toolbar__group {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .reader-toolbar__group--actions {
    margin-left: auto;
  }

  .reader-toolbar__label {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    white-space: nowrap;
  }

  /* Font size control */
  .reader-size {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    padding: 3px;
  }

  .reader-size__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 30px;
    height: 30px;
    border: none;
    background: transparent;
    color: var(--text-secondary);
    font-size: var(--text-lg);
    line-height: 1;
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .reader-size__btn:hover,
  .reader-size__btn:focus-visible {
    background: var(--surface-gold);
    color: var(--gold-400);
  }

  .reader-size__btn--reset {
    color: var(--text-muted);
  }

  .reader-size__value {
    min-width: 46px;
    text-align: center;
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--text-primary);
    font-variant-numeric: tabular-nums;
  }

  /* Translation buttons */
  .reader-langs {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .reader-lang {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-1) var(--space-3);
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    cursor: pointer;
    transition: all var(--transition-fast);
    font-size: var(--text-sm);
  }

  .reader-lang:not(.reader-lang--active):hover,
  .reader-lang:not(.reader-lang--active):focus-visible {
    border-color: var(--gold-400);
    color: var(--gold-400);
  }

  .reader-lang__symbol {
    font-weight: 700;
  }

  .reader-lang__name {
    text-transform: capitalize;
  }

  .reader-lang--active {
    background: linear-gradient(135deg, var(--gold-400), var(--gold-500));
    border-color: var(--gold-400);
    color: var(--text-inverse);
  }

  .reader-lang--active .reader-lang__name {
    color: var(--text-inverse);
  }

  /* Translation switcher - sits centered on the parchment, above the content.
     The parchment is always a warm cream (independent of site theme), so this
     is styled with parchment tones rather than theme variables. */
  .reader-translate {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    width: max-content;
    max-width: 100%;
    margin: 0 auto var(--space-8);
    padding: var(--space-2) var(--space-4);
    background: #fffdf5;
    border: 1px solid var(--parchment-border);
    border-radius: var(--radius-full);
    box-shadow: 0 4px 16px rgba(139, 69, 19, 0.18);
  }

  .reader-translate__label {
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: #8a6d3b;
    white-space: nowrap;
  }

  .reader-translate .reader-lang {
    background: #ffffff;
    border-color: var(--parchment-border);
    color: #6b4423;
  }

  .reader-translate .reader-lang:not(.reader-lang--active):hover,
  .reader-translate .reader-lang:not(.reader-lang--active):focus-visible {
    border-color: var(--saffron-500);
    color: var(--saffron-600);
  }

  .reader-translate .reader-lang--active {
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    border-color: transparent;
    color: #ffffff;
    box-shadow: var(--shadow-sm);
  }

  .reader-translate .reader-lang--active .reader-lang__name {
    color: #ffffff;
  }

  /* Action buttons */
  .reader-action {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-4);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-subtle);
    background: var(--surface-hover);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .reader-action:hover,
  .reader-action:focus-visible {
    border-color: var(--gold-400);
    color: var(--gold-400);
    background: var(--surface-gold);
  }

  #download-pdf-btn {
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    color: #fff;
    border-color: transparent;
  }

  #download-pdf-btn:hover {
    color: #fff;
    box-shadow: var(--shadow-md);
    transform: translateY(-1px);
  }

  #download-pdf-btn:disabled {
    opacity: 0.7;
    cursor: not-allowed;
    transform: none;
  }

  /* PDF export modal */
  .pdf-modal {
    position: fixed;
    inset: 0;
    z-index: var(--z-modal);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4);
  }

  .pdf-modal[hidden] {
    display: none;
  }

  .pdf-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    backdrop-filter: blur(2px);
  }

  .pdf-modal__dialog {
    position: relative;
    width: min(440px, 100%);
    max-height: calc(100vh - var(--space-8));
    overflow-y: auto;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
    animation: pdfModalIn 0.18s ease-out;
  }

  @keyframes pdfModalIn {
    from { opacity: 0; transform: translateY(10px) scale(0.98); }
    to { opacity: 1; transform: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .pdf-modal__dialog {
      animation: none;
    }
  }

  .pdf-modal__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    margin-bottom: 14px;
  }

  .pdf-modal__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
  }

  .pdf-modal__close {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border: none;
    background: transparent;
    color: var(--text-muted);
    border-radius: var(--radius-full);
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .pdf-modal__close:hover,
  .pdf-modal__close:focus-visible {
    background: var(--surface-hover);
    color: var(--text-primary);
  }

  .pdf-modal__hint {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin: var(--space-1) 0 var(--space-4);
  }

  .pdf-modal__group {
    margin-bottom: var(--space-4);
  }

  .pdf-modal__label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-muted);
    margin-bottom: var(--space-2);
  }

  .pdf-modal__options {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  .pdf-opt {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) var(--space-3);
    background: var(--surface-hover);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-full);
    color: var(--text-secondary);
    font-size: var(--text-sm);
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-fast);
  }

  .pdf-opt:not([aria-pressed="true"]):hover,
  .pdf-opt:not([aria-pressed="true"]):focus-visible {
    border-color: var(--gold-400);
    color: var(--gold-400);
  }

  .pdf-opt__symbol {
    font-weight: 700;
  }

  .pdf-opt__name {
    text-transform: capitalize;
  }

  .pdf-opt[aria-pressed="true"] {
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    border-color: transparent;
    color: #fff;
    box-shadow: var(--shadow-sm);
  }

  .pdf-modal__download {
    width: 100%;
    justify-content: center;
    margin-top: var(--space-2);
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    color: #fff;
    border-color: transparent;
  }

  .pdf-modal__download:hover,
  .pdf-modal__download:focus-visible {
    color: #fff;
    box-shadow: var(--shadow-md);
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
  }

  @media (max-width: 640px) {
    .reader-toolbar {
      gap: var(--space-3);
    }
    .reader-toolbar__group--actions {
      margin-left: 0;
      width: 100%;
    }
    .reader-toolbar__group--actions .reader-action {
      flex: 1;
      justify-content: center;
    }

    /* Wrapped buttons inside a border-radius: full pill collide with the
       rounded ends on narrow screens. Scroll horizontally instead of wrapping. */
    .reader-translate {
      flex-direction: column;
      align-items: stretch;
      width: 100%;
      gap: var(--space-2);
    }
    .reader-langs {
      flex-wrap: nowrap;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      max-width: 100%;
      width: fit-content;
    }
    .reader-langs::-webkit-scrollbar {
      display: none;
    }
    .reader-lang {
      flex-shrink: 0;
    }
  }
</style>

<script>
  document.addEventListener("DOMContentLoaded", () => {
    // --- Font size (reader zoom), persisted across pages ---
    const docBody = document.getElementById("docBody");
    const percent = document.getElementById("font-percent");
    const MIN = 0.8, MAX = 1.6, STEP = 0.1;
    let scale = parseFloat(localStorage.getItem("reader-scale") || "1");
    if (!Number.isFinite(scale)) scale = 1;

    const apply = () => {
      scale = Math.min(MAX, Math.max(MIN, Math.round(scale * 100) / 100));
      if (docBody) docBody.style.setProperty("--reader-scale", String(scale));
      if (percent) percent.textContent = Math.round(scale * 100) + "%";
      localStorage.setItem("reader-scale", String(scale));
    };

    document.getElementById("font-decrease")?.addEventListener("click", () => { scale -= STEP; apply(); });
    document.getElementById("font-increase")?.addEventListener("click", () => { scale += STEP; apply(); });
    document.getElementById("font-reset")?.addEventListener("click", () => { scale = 1; apply(); });
    if (docBody) apply();

    // --- Share ---
    const shareBtn = document.getElementById("share-btn");
    const shareLabel = document.getElementById("share-label");
    shareBtn?.addEventListener("click", async () => {
      const nav = navigator as any;
      const data = { title: document.title, url: window.location.href };
      try {
        if (nav.share) {
          await nav.share(data);
        } else if (nav.clipboard) {
          await nav.clipboard.writeText(window.location.href);
          if (shareLabel) {
            const prev = shareLabel.textContent;
            shareLabel.textContent = "Link copied!";
            setTimeout(() => { if (shareLabel) shareLabel.textContent = prev; }, 2000);
          }
        }
      } catch (e) {
        /* user cancelled the share sheet, or API unsupported */
      }
    });

    // --- PDF export modal ---
    // The toolbar button opens a confirm dialog pre-filled with the current
    // reading state; the actual generation lives in the page script and is
    // triggered via a "pdf-export" event carrying the chosen script/language.
    const pdfModal = document.getElementById("pdf-modal");
    const downloadBtn = document.getElementById("download-pdf-btn");

    const requestPdfExport = (detail: { script: string; lang: string | null }) => {
      document.dispatchEvent(new CustomEvent("pdf-export", { detail }));
    };

    const currentReadingState = (): { script: string; lang: string | null } => {
      const versesEl = document.querySelector(".verses");
      if (versesEl) {
        return {
          script: versesEl.getAttribute("data-script") || "devanagari",
          lang: versesEl.getAttribute("data-lang"),
        };
      }
      const activeLang = document.querySelector(".reader-lang--active");
      return {
        script: "devanagari",
        lang: activeLang ? activeLang.id.replace(/^lang-/, "") : null,
      };
    };

    if (pdfModal) {
      const groups = pdfModal.querySelectorAll<HTMLElement>(".pdf-modal__options");
      const confirmBtn = document.getElementById("pdf-modal-download");

      const setActive = (group: HTMLElement, value: string | null) => {
        group.querySelectorAll<HTMLButtonElement>(".pdf-opt").forEach((btn) => {
          btn.setAttribute("aria-pressed", btn.dataset.value === value ? "true" : "false");
        });
      };

      groups.forEach((group) => {
        group.querySelectorAll<HTMLButtonElement>(".pdf-opt").forEach((btn) => {
          btn.addEventListener("click", () => setActive(group, btn.dataset.value ?? null));
        });
      });

      const openModal = () => {
        const current = currentReadingState();
        groups.forEach((group) => {
          const wanted = group.dataset.role === "script" ? current.script : current.lang;
          const values = Array.from(
            group.querySelectorAll<HTMLButtonElement>(".pdf-opt"),
            (btn) => btn.dataset.value ?? null
          );
          setActive(group, wanted && values.includes(wanted) ? wanted : values[0]);
        });
        pdfModal.hidden = false;
        document.body.style.overflow = "hidden";
        confirmBtn?.focus();
      };

      const closeModal = () => {
        pdfModal.hidden = true;
        document.body.style.overflow = "";
        downloadBtn?.focus();
      };

      downloadBtn?.addEventListener("click", openModal);
      pdfModal.querySelectorAll("[data-pdf-close]").forEach((el) => {
        el.addEventListener("click", closeModal);
      });
      document.addEventListener("keydown", (e) => {
        if (e.key === "Escape" && !pdfModal.hidden) closeModal();
      });

      confirmBtn?.addEventListener("click", () => {
        const chosen: { script: string; lang: string | null } = currentReadingState();
        groups.forEach((group) => {
          const active = group.querySelector<HTMLButtonElement>('.pdf-opt[aria-pressed="true"]');
          if (!active) return;
          if (group.dataset.role === "script") chosen.script = active.dataset.value || chosen.script;
          else chosen.lang = active.dataset.value ?? chosen.lang;
        });
        closeModal();
        requestPdfExport(chosen);
      });
    } else {
      // No real choice on this page - download straight away with whatever
      // the reader is showing.
      downloadBtn?.addEventListener("click", () => requestPdfExport(currentReadingState()));
    }
  });
</script>
