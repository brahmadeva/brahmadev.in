---
import { SITE_TITLE, Tags } from "../utils/consts";
import { getPublished } from "../utils/content";

const allPages = await getPublished("page");

// Count items per tag
const tagCounts: Record<string, number> = {};
Tags.forEach(tag => {
  tagCounts[tag] = allPages.filter(p => p.data.tags?.includes(tag)).length;
});
---

<footer class="site-footer" role="contentinfo">
  <div class="footer__container">
    <!-- Column 1: Brand -->
    <div class="footer__brand">
      <a href="/" class="footer__logo">
        <img src="/assets/images/brahma-icon.png" alt="" width="40" height="40" class="footer__logo-img" />
        <span class="footer__logo-text">
          <span class="footer__logo-main">{SITE_TITLE}</span>
          <span class="footer__logo-tagline">श्री ब्रह्मा देव</span>
        </span>
      </a>
      <p class="footer__mission">
        A digital repository of authentic Vedic and Puranic sacred texts dedicated to the Creator God, Lord Brahma.
      </p>
    </div>

    <!-- Column 2: Quick Links -->
    <div class="footer__column">
      <h3 class="footer__heading">Quick Links</h3>
      <ul class="footer__links" role="list">
        <li><a href="/">Home</a></li>
        <li><a href="/tags">All Scriptures</a></li>
        <li><a href="/articles">Articles</a></li>
        <li><a href="/rss.xml" target="_blank" rel="noopener noreferrer">RSS Feed</a></li>
        <li><a href="/sitemap.xml" target="_blank" rel="noopener noreferrer">Sitemap</a></li>
        <li><a href="https://github.com/brahmadeva/brahmadev.in" target="_blank" rel="noopener noreferrer">GitHub Source</a></li>
      </ul>
    </div>

    <!-- Column 3: Sacred Collections -->
    <div class="footer__column">
      <h3 class="footer__heading">Sacred Collections</h3>
      <ul class="footer__links" role="list">
        {Tags.map(tag => (
          <li>
            <a href={`/tags/${tag}`}>
              {tag.charAt(0).toUpperCase() + tag.slice(1)}
              <span class="footer__count">{tagCounts[tag]}</span>
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- Column 4: About -->
    <div class="footer__column">
      <h3 class="footer__heading">About</h3>
      <p class="footer__about-text">
        All content is dedicated to the public domain under Creative Commons Zero 1.0.
      </p>
      <div class="footer__license">
        <a
          href="http://creativecommons.org/publicdomain/zero/1.0?ref=chooser-v1"
          target="_blank"
          rel="license noopener noreferrer"
          class="footer__license-link"
        >
          <img
            src="https://mirrors.creativecommons.org/presskit/icons/cc.svg?ref=chooser-v1"
            alt="Creative Commons"
            width="22"
            height="22"
            loading="lazy"
          />
          <img
            src="https://mirrors.creativecommons.org/presskit/icons/zero.svg?ref=chooser-v1"
            alt="CC0"
            width="22"
            height="22"
            loading="lazy"
          />
          <span>CC0 1.0</span>
        </a>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="footer__bottom">
    <p>© {new Date().getFullYear()} brahmadev.in — Dedicated to the public domain</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--space-20);
    border-top: 1px solid var(--border-subtle);
    background: var(--bg-secondary);
  }

  .footer__container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-12) var(--space-6);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-10);
  }

  /* Brand */
  .footer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--text-primary);
    margin-bottom: var(--space-4);
  }

  .footer__logo-img {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-gold);
  }

  .footer__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .footer__logo-main {
    font-size: var(--text-base);
    font-weight: 700;
  }

  .footer__logo-tagline {
    font-size: var(--text-xs);
    color: var(--gold-400);
    font-family: var(--font-devanagari);
  }

  .footer__mission {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 300px;
  }

  /* Columns */
  .footer__heading {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: var(--space-4);
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .footer__links a {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .footer__links a:hover {
    color: var(--gold-400);
  }

  .footer__count {
    font-size: var(--text-xs);
    background: var(--surface-hover);
    color: var(--text-muted);
    padding: 1px 8px;
    border-radius: var(--radius-full);
  }

  .footer__about-text {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-4);
  }

  .footer__license-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    transition: color var(--transition-fast);
  }

  .footer__license-link:hover {
    color: var(--text-primary);
  }

  .footer__license-link img {
    opacity: 0.7;
    transition: opacity var(--transition-fast);
  }

  .footer__license-link:hover img {
    opacity: 1;
  }

  /* Bottom Bar */
  .footer__bottom {
    border-top: 1px solid var(--border-subtle);
    padding: var(--space-5) var(--space-6);
    text-align: center;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin: 0;
  }

  /* Responsive */
  @media (min-width: 640px) {
    .footer__container {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .footer__container {
      grid-template-columns: 1.5fr 1fr 1fr 1fr;
    }
  }
</style>
