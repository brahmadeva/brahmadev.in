---
import { SITE_TITLE, Tags } from "../utils/consts";

const currentPath = Astro.url.pathname;

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Scriptures", href: "/tags" },
  { label: "Articles", href: "/articles" },
  ...Tags.map(tag => ({
    label: tag.charAt(0).toUpperCase() + tag.slice(1),
    href: `/tags/${tag}`,
  })),
];

// Precise active-state matching so a sub-category (e.g. /tags/stuti)
// highlights ONLY that link - not the "Scriptures" (/tags) parent too.
const normalizePath = (p: string) => (p !== "/" && p.endsWith("/") ? p.slice(0, -1) : p);
const cur = normalizePath(currentPath);
const isActive = (href: string) => {
  if (href === "/") return cur === "/";
  const h = normalizePath(href);
  if (h === "/tags") return cur === "/tags"; // index only, not /tags/<tag>
  return cur === h || cur.startsWith(h + "/");
};
---

<a href="#main-content" class="skip-link">Skip to content</a>

<header
  id="site-header"
  class="topbar"
>
  <nav class="topbar__container" aria-label="Main navigation">
    <!-- Logo -->
    <a
      id="TOPBAR_SITE_TITLE"
      class="topbar__logo"
      href="/"
    >
      <img
        src="/assets/images/brahma-icon.png"
        class="topbar__logo-img"
        alt=""
        width="40"
        height="40"
      />
      <span class="topbar__logo-text">
        <span class="topbar__logo-main">{SITE_TITLE}</span>
        <span class="topbar__logo-tagline">श्री ब्रह्मा देव</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <ul class="topbar__nav" role="list">
      {navLinks.map(link => (
        <li>
          <a
            class:list={["topbar__nav-link", { active: isActive(link.href) }]}
            href={link.href}
            aria-current={isActive(link.href) ? "page" : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Desktop Actions -->
    <div class="topbar__actions">
      <button
        class="topbar__theme-btn"
        aria-label="Toggle light/dark theme"
        id="theme-toggle-desktop"
      >
        <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <button
        class="topbar__search-btn"
        aria-label="Search (Ctrl+K)"
        id="open-modal-btn"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
        <span class="topbar__search-hint">Ctrl+K</span>
      </button>
    </div>

    <!-- Mobile Controls -->
    <div class="topbar__mobile-controls">
      <button
        class="topbar__theme-btn"
        aria-label="Toggle light/dark theme"
        id="theme-toggle-mobile"
      >
        <svg class="theme-icon-sun" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="4"></circle><path d="M12 2v2"></path><path d="M12 20v2"></path><path d="m4.93 4.93 1.41 1.41"></path><path d="m17.66 17.66 1.41 1.41"></path><path d="M2 12h2"></path><path d="M20 12h2"></path><path d="m6.34 17.66-1.41 1.41"></path><path d="m19.07 4.93-1.41 1.41"></path>
        </svg>
        <svg class="theme-icon-moon" xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"></path>
        </svg>
      </button>

      <button
        class="topbar__search-btn-mobile"
        aria-label="Search"
        id="open-modal-btn-mobile"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="8"></circle>
          <path d="m21 21-4.3-4.3"></path>
        </svg>
      </button>
      <button
        class="topbar__hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-drawer"
        id="hamburger-btn"
      >
        <svg class="topbar__hamburger-icon" xmlns="http://www.w3.org/2000/svg" width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="4" y1="6" x2="20" y2="6" class="hamburger-top"></line>
          <line x1="4" y1="12" x2="20" y2="12" class="hamburger-mid"></line>
          <line x1="4" y1="18" x2="20" y2="18" class="hamburger-bot"></line>
        </svg>
      </button>
    </div>
  </nav>
</header>

<!-- Mobile Drawer -->
<div
  class="drawer-backdrop"
  id="drawer-backdrop"
  aria-hidden="true"
></div>
<aside
  class="drawer"
  id="mobile-drawer"
  role="dialog"
  aria-label="Navigation menu"
  aria-modal="true"
  inert
>
  <div class="drawer__header">
    <a href="/" class="drawer__logo">
      <img src="/assets/images/brahma-icon.png" alt="" width="36" height="36" class="drawer__logo-img" />
      <span>{SITE_TITLE}</span>
    </a>
    <button
      class="drawer__close"
      aria-label="Close menu"
      id="drawer-close-btn"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M18 6 6 18"></path>
        <path d="m6 6 12 12"></path>
      </svg>
    </button>
  </div>
  
  <nav class="drawer__nav" aria-label="Mobile navigation">
    <div class="drawer__section">
      <span class="drawer__section-label">Main</span>
      <a href="/" class:list={["drawer__link", { active: currentPath === "/" }]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9,22 9,12 15,12 15,22"></polyline></svg>
        Home
      </a>
      <a href="/tags" class:list={["drawer__link", { active: currentPath === "/tags" || currentPath === "/tags/" }]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"></path></svg>
        All Scriptures
      </a>
      <a href="/articles" class:list={["drawer__link", { active: currentPath === "/articles" || currentPath.startsWith("/articles/") }]}>
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
        Articles
      </a>
    </div>
    <div class="drawer__section">
      <span class="drawer__section-label">Categories</span>
      {Tags.map(tag => (
        <a
          href={`/tags/${tag}`}
          class:list={["drawer__link", { active: currentPath === `/tags/${tag}` || currentPath === `/tags/${tag}/` }]}
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"></path><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"></circle></svg>
          {tag.charAt(0).toUpperCase() + tag.slice(1)}
        </a>
      ))}
    </div>
  </nav>

  <div class="drawer__footer">
    <a href="https://github.com/brahmadeva/brahmadev.in" target="_blank" rel="noopener noreferrer" class="drawer__link drawer__link--external">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path></svg>
      View Source
    </a>
  </div>
</aside>

<style>
  /* ===================================
     TOPBAR
     =================================== */
  .topbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: var(--z-sticky);
    background: var(--bg-glass);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-subtle);
    height: var(--nav-height);
    transition: background var(--transition-base), border-color var(--transition-base);
  }

  /* At the top of a page with the dark cosmic hero, the bar blends into the
     hero (transparent, light text) in BOTH themes; on scroll it becomes the
     themed glass bar. Prevents the awkward white bar over the dark hero. */
  .topbar--over-hero:not(.topbar--scrolled) {
    background: transparent;
    border-bottom-color: transparent;
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
    --text-primary: #f5f1e8;
    --text-secondary: #e6ddcf;
    --text-muted: #cabfad;
    --gold-400: #eabb2e;
    --border-subtle: rgba(255, 255, 255, 0.14);
    --border-default: rgba(255, 255, 255, 0.2);
    --surface-hover: rgba(255, 255, 255, 0.12);
    --surface-hover-strong: rgba(255, 255, 255, 0.18);
  }

  .topbar__container {
    max-width: var(--content-max-width);
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    padding: 0 var(--space-4);
  }

  /* Logo */
  .topbar__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    text-decoration: none;
    color: var(--text-primary);
    flex-shrink: 0;
  }

  .topbar__logo-img {
    width: 36px;
    height: 36px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-gold);
    object-fit: cover;
  }

  .topbar__logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
  }

  .topbar__logo-main {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text-primary);
  }

  .topbar__logo-tagline {
    font-size: var(--text-xs);
    color: var(--gold-400);
    font-family: var(--font-devanagari);
  }

  /* Desktop Nav */
  .topbar__nav {
    display: none;
    list-style: none;
    gap: var(--space-1);
    margin: 0;
    padding: 0;
  }

  .topbar__nav-link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-sm);
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
    white-space: nowrap;
  }

  .topbar__nav-link:hover {
    color: var(--text-primary);
    background: var(--surface-hover);
  }

  .topbar__nav-link.active {
    color: var(--gold-400);
    background: rgba(212, 160, 23, 0.1);
  }

  /* Desktop Actions */
  .topbar__actions {
    display: none;
  }

  .topbar__theme-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    padding: var(--space-2);
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .topbar__theme-btn:hover,
  .topbar__theme-btn:focus-visible {
    color: var(--gold-400);
    background: rgba(212, 160, 23, 0.08);
  }

  /* Icon swap for the theme toggle. `data-theme` is set on <html>, which is
     OUTSIDE this component's scope - so the ancestor must be :global() or Astro
     scopes it to an element that doesn't exist and the swap never happens.
     Convention: dark shows the sun, light shows the moon. */
  .theme-icon-moon {
    display: none;
  }

  :global([data-theme="light"]) .theme-icon-sun {
    display: none;
  }

  :global([data-theme="light"]) .theme-icon-moon {
    display: block;
  }

  .topbar__search-btn {
    display: none; /* hidden on mobile */
  }

  @media (min-width: 768px) {
    .topbar__search-btn {
      display: flex;
      align-items: center;
      gap: var(--space-2);
      padding: var(--space-2) var(--space-3);
      background: var(--surface-hover);
      border: 1px solid var(--border-subtle);
      border-radius: var(--radius-md);
      color: var(--text-muted);
      cursor: pointer;
      transition: all var(--transition-fast);
      font-size: var(--text-sm);
    }
  }

  .topbar__search-btn:hover {
    background: var(--surface-hover-strong);
    border-color: var(--border-default);
    color: var(--text-primary);
  }

  .topbar__search-hint {
    font-size: var(--text-xs);
    padding: 2px 6px;
    background: var(--surface-hover-strong);
    border-radius: var(--radius-sm);
    font-family: monospace;
  }

  /* Mobile Controls */
  .topbar__mobile-controls {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .topbar__search-btn-mobile,
  .topbar__hamburger {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    background: transparent;
    border: none;
    color: var(--text-secondary);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .topbar__search-btn-mobile:hover,
  .topbar__hamburger:hover {
    color: var(--text-primary);
    background: var(--surface-hover);
  }

  /* Hamburger animation */
  .hamburger-top,
  .hamburger-mid,
  .hamburger-bot {
    transition: all var(--transition-base);
    transform-origin: center;
  }

  /* ===================================
     DRAWER
     =================================== */
  .drawer-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    z-index: var(--z-overlay);
    opacity: 0;
    visibility: hidden;
    transition: opacity var(--transition-base), visibility var(--transition-base);
  }

  .drawer-backdrop.open {
    opacity: 1;
    visibility: visible;
  }

  .drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: min(320px, 85vw);
    background: var(--bg-secondary);
    border-left: 1px solid var(--border-subtle);
    z-index: var(--z-modal);
    transform: translateX(100%);
    transition: transform var(--transition-slow);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    overscroll-behavior: contain;
  }

  .drawer.open {
    transform: translateX(0);
  }

  .drawer__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-4) var(--space-5);
    border-bottom: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }

  .drawer__logo {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    color: var(--text-primary);
    text-decoration: none;
    font-weight: 700;
    font-size: var(--text-base);
  }

  .drawer__logo-img {
    width: 32px;
    height: 32px;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-gold);
  }

  .drawer__close {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: transparent;
    border: none;
    color: var(--text-muted);
    cursor: pointer;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .drawer__close:hover {
    color: var(--text-primary);
    background: var(--surface-hover-strong);
  }

  .drawer__nav {
    flex: 1;
    padding: var(--space-4) 0;
    overflow-y: auto;
  }

  .drawer__section {
    padding: 0 var(--space-4);
    margin-bottom: var(--space-6);
  }

  .drawer__section-label {
    display: block;
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0 var(--space-3);
    margin-bottom: var(--space-2);
  }

  .drawer__link {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-3);
    color: var(--text-secondary);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 500;
    border-radius: var(--radius-md);
    transition: all var(--transition-fast);
  }

  .drawer__link:hover {
    color: var(--text-primary);
    background: var(--surface-hover);
  }

  .drawer__link.active {
    color: var(--gold-400);
    background: rgba(212, 160, 23, 0.1);
  }

  .drawer__link--external {
    color: var(--text-muted);
  }

  .drawer__footer {
    padding: var(--space-4) var(--space-5);
    border-top: 1px solid var(--border-subtle);
    flex-shrink: 0;
  }

  /* ===================================
     RESPONSIVE
     =================================== */
  @media (min-width: 1024px) {
    .topbar__nav {
      display: flex;
    }

    .topbar__actions {
      display: flex;
      align-items: center;
      gap: var(--space-3);
    }

    .topbar__mobile-controls {
      display: none;
    }
  }
</style>

<script>
  // Transparent topbar while over the homepage's dark hero; solidifies on scroll.
  const header = document.getElementById('site-header');
  const heroEl = document.querySelector('.hero');
  if (header && heroEl) {
    header.classList.add('topbar--over-hero');
    const onScroll = () => {
      header.classList.toggle('topbar--scrolled', window.scrollY > 24);
    };
    onScroll();
    window.addEventListener('scroll', onScroll, { passive: true });
  }

  // Mobile drawer functionality
  const hamburger = document.getElementById('hamburger-btn');
  const drawer = document.getElementById('mobile-drawer');
  const backdrop = document.getElementById('drawer-backdrop');
  const closeBtn = document.getElementById('drawer-close-btn');

  const getFocusable = (): HTMLElement[] =>
    drawer
      ? Array.from(
          drawer.querySelectorAll<HTMLElement>('a[href], button:not([disabled])')
        ).filter((el) => el.offsetParent !== null)
      : [];

  // Keep keyboard focus inside the drawer while it is open
  const trapFocus = (e: KeyboardEvent) => {
    if (e.key !== 'Tab' || !drawer?.classList.contains('open')) return;
    const focusable = getFocusable();
    if (focusable.length === 0) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  };

  function openDrawer() {
    drawer?.classList.add('open');
    backdrop?.classList.add('open');
    hamburger?.setAttribute('aria-expanded', 'true');
    drawer?.removeAttribute('inert');
    document.body.style.overflow = 'hidden';
    document.addEventListener('keydown', trapFocus);
    // Focus the close button
    closeBtn?.focus();
  }

  function closeDrawer() {
    drawer?.classList.remove('open');
    backdrop?.classList.remove('open');
    hamburger?.setAttribute('aria-expanded', 'false');
    drawer?.setAttribute('inert', '');
    document.body.style.overflow = '';
    document.removeEventListener('keydown', trapFocus);
    // Return focus to hamburger
    hamburger?.focus();
  }

  hamburger?.addEventListener('click', openDrawer);
  closeBtn?.addEventListener('click', closeDrawer);
  backdrop?.addEventListener('click', closeDrawer);

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && drawer?.classList.contains('open')) {
      closeDrawer();
    }
  });

  // Close drawer links when navigating
  drawer?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      closeDrawer();
    });
  });
</script>
