---
import { Tags } from "../utils/consts";
const { pages } = Astro.props;
---

<div class="cards-grid">
  {pages.map((post: any, i: number) => (
    <a href={`/page/${post.slug}/`} class="card fade-in-on-scroll" style={`--reveal-delay: ${Math.min(i, 8) * 50}ms`}>
      <div class="card__body">
        <div class="card__tags">
          {post.data.tags?.filter((t: string) => Tags.includes(t)).slice(0, 2).map((tag: string) => (
            <span class="card__tag">{tag}</span>
          ))}
        </div>
        <h2 class="card__title" lang="hi">{post.data.titleDevanagri}</h2>
        <h3 class="card__subtitle">{post.data.titleEnglish}</h3>
        {post.data.description && (
          <p class="card__desc">
            {post.data.description.replaceAll('<br />', ' ').replaceAll('<br/>', ' ').replace(/<[^>]*>/g, '').slice(0, 120)}
          </p>
        )}
      </div>
      <div class="card__footer">
        <span class="card__read-more">
          Read More
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14"></path><path d="m12 5 7 7-7 7"></path></svg>
        </span>
      </div>
    </a>
  ))}
</div>

<style>
  .cards-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
    width: 100%;
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-4);
  }

  .card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    text-decoration: none;
    transition: all var(--transition-base);
    overflow: hidden;
  }

  .card:hover {
    border-color: var(--border-gold);
    box-shadow: var(--shadow-gold);
    transform: translateY(-2px);
  }

  .card__body {
    padding: var(--space-5);
    flex: 1;
  }

  .card__tags {
    display: flex;
    gap: var(--space-2);
    margin-bottom: var(--space-3);
  }

  .card__tag {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--gold-400);
    background: rgba(212, 160, 23, 0.1);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    padding: 2px 10px;
  }

  .card__title {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
    font-family: var(--font-devanagari);
    line-height: var(--leading-normal);
    margin-bottom: var(--space-1);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__subtitle {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: var(--space-3);
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__desc {
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .card__footer {
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--border-subtle);
  }

  .card__read-more {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--gold-400);
    transition: gap var(--transition-fast);
  }

  .card:hover .card__read-more {
    gap: var(--space-3);
  }

  @media (min-width: 480px) {
    .cards-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 768px) {
    .cards-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .cards-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
</style>
