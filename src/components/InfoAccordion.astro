---
interface InfoSection {
  icon: string;
  titleEn: string;
  titleHi: string;
  content: string;
  open?: boolean;
}

interface Props {
  sections: InfoSection[];
}

const { sections } = Astro.props;

const iconMap: Record<string, string> = {
  significance: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"></path></svg>',
  benefits: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 9.5a5.5 5.5 0 0 1 9.591-3.676.56.56 0 0 0 .818 0A5.49 5.49 0 0 1 22 9.5c0 2.29-1.5 4-3 5.5l-5.492 5.313a2 2 0 0 1-3 .019L5 15c-1.5-1.5-3-3.2-3-5.5"></path></svg>',
  recitation: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"></path></svg>',
  viniyog: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path><path d="M12 17h.01"></path></svg>',
  source: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>',
};
---

{sections.length > 0 && (
  <div class="info-accordions">
    <h2 class="info-accordions__title">
      <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><path d="M12 16v-4"></path><path d="M12 8h.01"></path></svg>
      Additional Information
      <span class="info-accordions__subtitle">अतिरिक्त जानकारी</span>
    </h2>
    {sections.map((section) => (
      <details class="info-accordion" open={section.open}>
        <summary class="info-accordion__summary">
          <span class="info-accordion__icon" set:html={iconMap[section.icon] || iconMap.significance} />
          <span class="info-accordion__titles">
            <span class="info-accordion__title-en">{section.titleEn}</span>
            <span class="info-accordion__title-hi">{section.titleHi}</span>
          </span>
          <svg class="info-accordion__chevron" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m6 9 6 6 6-6"></path></svg>
        </summary>
        <div class="info-accordion__content" set:html={section.content} />
      </details>
    ))}
  </div>
)}

<style>
  .info-accordions {
    margin-top: var(--space-10);
  }

  .info-accordions__title {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-lg);
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-3);
    border-bottom: 1px solid var(--border-subtle);
  }

  .info-accordions__subtitle {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-devanagari);
    font-weight: 400;
    margin-left: auto;
  }

  .info-accordion {
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    margin-bottom: var(--space-3);
    overflow: hidden;
    transition: border-color var(--transition-fast);
  }

  .info-accordion:hover {
    border-color: var(--border-gold);
  }

  .info-accordion[open] {
    border-color: var(--border-gold);
  }

  .info-accordion__summary {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-4) var(--space-5);
    cursor: pointer;
    user-select: none;
    list-style: none;
    transition: background var(--transition-fast);
  }

  .info-accordion__summary::-webkit-details-marker {
    display: none;
  }

  .info-accordion__summary::marker {
    display: none;
    content: '';
  }

  .info-accordion__summary:hover {
    background: var(--surface-subtle);
  }

  .info-accordion__icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: rgba(212, 160, 23, 0.1);
    border-radius: var(--radius-md);
    color: var(--gold-400);
    flex-shrink: 0;
  }

  .info-accordion__titles {
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex: 1;
  }

  .info-accordion__title-en {
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--text-primary);
  }

  .info-accordion__title-hi {
    font-size: var(--text-sm);
    color: var(--text-muted);
    font-family: var(--font-devanagari);
  }

  .info-accordion__chevron {
    color: var(--text-muted);
    transition: transform var(--transition-base);
    flex-shrink: 0;
  }

  .info-accordion[open] .info-accordion__chevron {
    transform: rotate(180deg);
  }

  .info-accordion__content {
    padding: 0 var(--space-5) var(--space-5);
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    border-top: 1px solid var(--border-subtle);
    padding-top: var(--space-4);
    margin: 0 var(--space-5);
  }

  .info-accordion__content :global(p) {
    margin-bottom: var(--space-3);
  }

  .info-accordion__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .info-accordion__content :global(a) {
    color: var(--gold-400);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .info-accordion__content :global(ul),
  .info-accordion__content :global(ol) {
    margin: var(--space-2) 0 var(--space-3);
    padding-left: var(--space-5);
  }

  .info-accordion__content :global(li) {
    margin-bottom: var(--space-2);
    line-height: var(--leading-normal);
  }

  .info-accordion__content :global(li)::marker {
    color: var(--gold-400);
  }

  .info-accordion__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  @media (max-width: 640px) {
    .info-accordion__summary {
      padding: var(--space-3) var(--space-4);
    }

    .info-accordion__content {
      padding: 0 var(--space-4) var(--space-4);
      margin: 0 var(--space-4);
    }

    .info-accordions__subtitle {
      display: none;
    }
  }
</style>
