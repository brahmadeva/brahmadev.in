---
import { type CollectionEntry } from "astro:content";
import { getPublished } from "../../utils/content";
import Topbar from "../../components/Topbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import Sidebar from "../../components/Sidebar.astro";
import InfoAccordion from "../../components/InfoAccordion.astro";

import {
  SITE_TITLE_SEPARATOR,
  SITE_TITLE,
  SITE_TITLE_DEVANAGRI,
  DEFAULT_ARTICLE_IMAGE,
  Tags,
} from "../../utils/consts";
import MetadataHead from "../../components/MetadataHead.astro";
import ArticleBody from "../../components/ArticleBody.astro";
import SearchModal from "../../components/SearchModal.astro";

export async function getStaticPaths() {
  const pages = await getPublished("page");
  return pages.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<"page">;

const post = Astro.props;
const { Content } = await post.render();
const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { titleDevanagri, titleEnglish, description, heroImage, pubDate, tags } =
  post.data;

const ogSiteName = `${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const postTitleEnglish = `${titleEnglish} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const postTitleDevanagri = `${titleDevanagri} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE_DEVANAGRI}`;
const postTitleCombined = `${titleDevanagri} ${SITE_TITLE_SEPARATOR} ${titleEnglish} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const postDesciptionCombined = description;

const finalHeroImage = new URL(
  heroImage ? heroImage : DEFAULT_ARTICLE_IMAGE,
  Astro.url,
);

// Build breadcrumb
const primaryTag = tags?.find((t) => Tags.includes(t));
const breadcrumbItems = [
  { label: "Home", href: "/" },
  ...(primaryTag
    ? [
        {
          label: primaryTag.charAt(0).toUpperCase() + primaryTag.slice(1),
          href: `/tags/${primaryTag}`,
        },
      ]
    : []),
  { label: titleEnglish },
];

// Build info accordion sections
const infoSections = [
  post.data.significance && {
    icon: "significance",
    titleEn: "Significance",
    titleHi: "महत्व",
    content: post.data.significance,
    open: true,
  },
  post.data.benefits && {
    icon: "benefits",
    titleEn: "Benefits of Reciting",
    titleHi: "पाठ के लाभ",
    content: post.data.benefits,
  },
  post.data.recitationMethod && {
    icon: "recitation",
    titleEn: "How to Recite",
    titleHi: "पाठ विधि",
    content: post.data.recitationMethod,
  },
  post.data.viniyog && {
    icon: "viniyog",
    titleEn: "Viniyog",
    titleHi: "विनियोग",
    content: post.data.viniyog,
  },
  (post.data.sourceName ||
    post.data.sourceDescription ||
    post.data.sourceLink ||
    post.data.extraInfo) && {
    icon: "source",
    titleEn: "Sources & References",
    titleHi: "स्रोत एवं संदर्भ",
    content: [
      post.data.sourceName
        ? `<p><strong>Source:</strong> ${post.data.sourceName}</p>`
        : "",
      post.data.sourceDescription
        ? `<p>${post.data.sourceDescription}</p>`
        : "",
      post.data.sourceLink
        ? `<p><strong>Reference:</strong> <a href="${post.data.sourceLink}" target="_blank" rel="noopener noreferrer">${post.data.sourceLink.length > 60 ? post.data.sourceLink.substring(0, 60) + "..." : post.data.sourceLink}</a></p>`
        : "",
      post.data.extraInfo ? `<p>${post.data.extraInfo}</p>` : "",
    ]
      .filter(Boolean)
      .join(""),
    open: true,
  },
].filter((s): s is Exclude<typeof s, "" | undefined | 0 | false | null> =>
  Boolean(s),
);

const ldSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  publisher: {
    "@type": "Organization",
    name: ogSiteName,
    url: "https://brahmadev.in/",
    logo: {
      "@type": "ImageObject",
      url: "https://brahmadev.in/assets/images/brahma-icon.png",
      width: 60,
      height: 60,
    },
  },
  headline: postTitleCombined,
  url: Astro.url,
  datePublished: pubDate,
  keywords: tags?.length ? tags.join(", ") : "",
  description: postDesciptionCombined,
  mainEntityOfPage: Astro.url,
};
---

<html lang="en">
  <head>
    <MetadataHead />

    <link rel="canonical" href={canonicalURL} />
    <title>{postTitleCombined}</title>

    <meta name="title" lang="en" content={postTitleEnglish} />
    <meta name="description" lang="en" content={description} />
    <meta name="title" lang="hi" content={postTitleDevanagri} />
    <meta name="description" lang="hi" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={postTitleCombined} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:description" content={postDesciptionCombined} />
    <meta property="og:locale" content="en_IN" />
    <meta property="og:locale:alternate" content="hi_IN" />
    <meta property="og:image" content={finalHeroImage} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={postTitleCombined} />
    <meta property="twitter:description" content={postDesciptionCombined} />
    <meta property="twitter:image" content={finalHeroImage} />

    <script type="application/ld+json" set:html={JSON.stringify(ldSchema)} />

    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"
    ></script>
    <script
      src="https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js"
    ></script>

    <script
      is:inline
      define:vars={{ titleDevanagri, titleEnglish, description }}
    >
      document.addEventListener("DOMContentLoaded", () => {
        const downloadBtn = document.getElementById("download-pdf-btn");
        if (downloadBtn) {
          downloadBtn.addEventListener("click", async () => {
            const originalText = downloadBtn.innerHTML;
            downloadBtn.innerHTML = `
              <svg class="spin-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24">
                <circle opacity="0.25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path opacity="0.75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
              </svg>
              <span>Generating PDF...</span>
            `;
            downloadBtn.disabled = true;
            try {
              const { jsPDF } = window.jspdf;
              const docBody = document.getElementById("docBody");
              if (!docBody) throw new Error("Content not found");

              const container = document.createElement("div");
              container.id = "pdf-export-root";
              container.style.cssText =
                'position:absolute;left:-9999px;width:800px;background:white;padding:32px 36px;font-family:"Noto Sans Devanagari","Noto Sans",sans-serif;color:#000;';
              document.body.appendChild(container);

              // PDF-only overrides: tighten the screen layout's generous
              // spacing and swap decorative chrome for a quieter print look.
              const pdfStyles = document.createElement("style");
              pdfStyles.textContent = `
                #pdf-export-root #docBody p { margin-bottom: 0.9rem !important; line-height: 1.95 !important; }
                #pdf-export-root #docBody h1, #pdf-export-root #docBody h2,
                #pdf-export-root #docBody h3, #pdf-export-root #docBody h4 {
                  margin-top: 1.4rem !important; margin-bottom: 0.8rem !important;
                }
                #pdf-export-root #docBody .verse { padding: 0.85rem 0 !important; border-bottom: 1px solid #ece1c6 !important; }
                #pdf-export-root #docBody .verse:last-child,
                #pdf-export-root #docBody .verse--colophon { border-bottom: none !important; }
                #pdf-export-root #docBody .verse__script { font-size: 1.3rem !important; line-height: 1.9 !important; }
                #pdf-export-root #docBody .verse__meaning { margin-top: 0.5rem !important; }
                #pdf-export-root #docBody .verse__trans {
                  background: transparent !important;
                  border-left: 2px solid #d8c9a8 !important;
                  border-radius: 0 !important;
                  padding: 0.15rem 0 0.15rem 1rem !important;
                  font-size: 0.95rem !important;
                  line-height: 1.8 !important;
                }
                #pdf-export-root #docBody .translation { margin: 0.4rem 0 0.9rem !important; line-height: 1.85 !important; }
                #pdf-export-root #docBody .sanskrit-shlok { padding: 0.3rem 0 !important; margin-bottom: 0.9rem !important; }
              `;
              container.appendChild(pdfStyles);

              // Minimal title block: site mark, titles, short rule
              const plainDescription = description
                ? description.replace(/<[^>]*>/g, "")
                : "";
              const titleSection = document.createElement("div");
              titleSection.innerHTML = `
                <div style="text-align:center;margin-bottom:34px;">
                  <div style="font-size:10px;letter-spacing:3px;text-transform:uppercase;color:#8b5922;margin-bottom:20px;">www.brahmadev.in</div>
                  <h1 style="font-size:27px;font-weight:700;margin:0 0 8px;color:#1a1a1a;line-height:1.45;">${titleDevanagri || ""}</h1>
                  <h2 style="font-size:15px;font-weight:500;margin:0;color:#555;line-height:1.5;">${titleEnglish || ""}</h2>
                  <div style="height:1px;background:linear-gradient(90deg,transparent,#c9a86a,transparent);width:280px;margin:22px auto;"></div>
                  ${plainDescription ? `<p style="font-size:13.5px;font-style:italic;line-height:1.8;color:#6f6a60;max-width:580px;margin:0 auto;">${plainDescription}</p>` : ""}
                </div>
              `;
              container.appendChild(titleSection);

              const contentClone = docBody.cloneNode(true);
              contentClone.style.setProperty("--reader-scale", "1");
              const clonedElements = contentClone.querySelectorAll("*");
              const originalElements = docBody.querySelectorAll("*");
              clonedElements.forEach((clonedEl, index) => {
                const originalEl = originalElements[index];
                if (originalEl) {
                  const cs = window.getComputedStyle(originalEl);
                  if (
                    cs.display === "none" ||
                    originalEl.offsetParent === null
                  ) {
                    clonedEl.remove();
                    return;
                  }
                }
                clonedEl.style.setProperty("color", "#000000", "important");
                clonedEl.style.setProperty(
                  "background-color",
                  "transparent",
                  "important",
                );
                clonedEl.style.setProperty("opacity", "1", "important");
                clonedEl.style.setProperty(
                  "visibility",
                  "visible",
                  "important",
                );
              });
              // Strip interactive controls (script/translation toggles etc.)
              contentClone
                .querySelectorAll('button, [role="toolbar"]')
                .forEach((el) => el.remove());
              container.appendChild(contentClone);

              await document.fonts.ready;
              await new Promise((r) => setTimeout(r, 300));

              const canvas = await html2canvas(container, {
                scale: 2,
                useCORS: true,
                backgroundColor: "#ffffff",
                logging: false,
                windowWidth: 800,
              });
              document.body.removeChild(container);

              // --- Paginate onto proper A4 pages ---
              const pageW = 210,
                pageH = 297;
              const margin = { top: 14, bottom: 16, left: 14, right: 14 };
              const contentW = pageW - margin.left - margin.right;
              const pxPerMm = canvas.width / contentW;
              const pageContentPx = Math.floor(
                (pageH - margin.top - margin.bottom) * pxPerMm,
              );

              // Prefer cutting pages at blank rows so text lines aren't sliced.
              const srcCtx = canvas.getContext("2d");
              const isBlankRow = (y) => {
                const row = srcCtx.getImageData(0, y, canvas.width, 1).data;
                for (let i = 0; i < row.length; i += 40) {
                  if (row[i] < 245 || row[i + 1] < 245 || row[i + 2] < 245)
                    return false;
                }
                return true;
              };
              const cuts = [];
              let yPx = 0;
              while (yPx < canvas.height) {
                let end = Math.min(yPx + pageContentPx, canvas.height);
                if (end < canvas.height) {
                  const searchLimit =
                    end - Math.min(400, Math.floor(pageContentPx * 0.25));
                  for (let k = end; k > searchLimit; k--) {
                    if (isBlankRow(k)) {
                      end = k;
                      break;
                    }
                  }
                }
                if (end <= yPx)
                  end = Math.min(yPx + pageContentPx, canvas.height);
                cuts.push([yPx, end]);
                yPx = end;
              }

              const _doc = new jsPDF({
                orientation: "portrait",
                unit: "mm",
                format: "a4",
              });
              _doc.setProperties({
                title: `${titleEnglish || titleDevanagri || ""}`,
                subject: plainDescription,
                author: "brahmadev.in",
                creator: "brahmadev.in",
              });

              cuts.forEach(([start, end], i) => {
                if (i > 0) _doc.addPage();
                const sliceH = end - start;
                const pageCanvas = document.createElement("canvas");
                pageCanvas.width = canvas.width;
                pageCanvas.height = sliceH;
                const pctx = pageCanvas.getContext("2d");
                pctx.fillStyle = "#ffffff";
                pctx.fillRect(0, 0, pageCanvas.width, pageCanvas.height);
                pctx.drawImage(
                  canvas,
                  0,
                  start,
                  canvas.width,
                  sliceH,
                  0,
                  0,
                  canvas.width,
                  sliceH,
                );
                _doc.addImage(
                  pageCanvas.toDataURL("image/jpeg", 0.92),
                  "JPEG",
                  margin.left,
                  margin.top,
                  contentW,
                  sliceH / pxPerMm,
                );

                // Minimal footer: site left, page number right
                _doc.setFont("helvetica", "normal");
                _doc.setFontSize(8);
                _doc.setTextColor(150);
                _doc.text("https://www.brahmadev.in", margin.left, pageH - 8);
                if (cuts.length > 1) {
                  _doc.text(
                    `${i + 1} / ${cuts.length}`,
                    pageW - margin.right,
                    pageH - 8,
                    { align: "right" },
                  );
                }
              });

              const safeTitle = (titleEnglish || titleDevanagri || "document")
                .replace(/[/\\?%*:|"<>]/g, "-")
                .replace(/\s+/g, " ")
                .trim();
              _doc.save(`${safeTitle}.pdf`);
            } catch (error) {
              console.error("Error generating PDF:", error);
              alert("Failed to generate PDF: " + error.message);
            } finally {
              downloadBtn.innerHTML = originalText;
              downloadBtn.disabled = false;
            }
          });
        }
      });
    </script>
  </head>

  <body>
    <Topbar />
    <SearchModal />

    <main id="main-content" class="content-page">
      <!-- Hero / Title Section -->
      <div class="content-page__hero">
        <div class="content-page__hero-inner">
          <Breadcrumb items={breadcrumbItems} />

          <!-- Tags -->
          <div class="content-page__tags">
            {
              post.data?.tags?.map((tag: string) =>
                Tags.includes(tag) ? (
                  <a href={`/tags/${tag}`} class="content-page__tag">
                    {tag.charAt(0).toUpperCase() + tag.slice(1)}
                  </a>
                ) : (
                  <span class="content-page__tag content-page__tag--plain">
                    {tag}
                  </span>
                ),
              )
            }
          </div>

          <!-- Title -->
          <h1 class="content-page__title" lang="hi">{titleDevanagri}</h1>
          <p class="content-page__title-en">{titleEnglish}</p>
          {
            description && (
              <p class="content-page__description" set:html={description} />
            )
          }

          <!-- Meta row: date + source -->
          <div class="content-page__meta">
            <span class="content-page__meta-item">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><rect width="18" height="18" x="3" y="4" rx="2" ry="2"
                ></rect><line x1="16" x2="16" y1="2" y2="6"></line><line
                  x1="8"
                  x2="8"
                  y1="2"
                  y2="6"></line><line x1="3" x2="21" y1="10" y2="10"
                ></line></svg
              >
              <time datetime={pubDate.toISOString()}>
                {
                  pubDate.toLocaleDateString("en-IN", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })
                }
              </time>
            </span>
            {
              post.data.sourceName && (
                <span class="content-page__meta-item">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="14"
                    height="14"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    aria-hidden="true"
                  >
                    <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20" />
                  </svg>
                  <span
                    set:html={post.data.sourceName
                      .replaceAll("<br/>", "")
                      .replaceAll("<br />", "")
                      .replaceAll("<br>", "")}
                  />
                </span>
              )
            }
          </div>
        </div>
      </div>

      <!-- 2-Column Layout: Content + Sidebar -->
      <div class="content-page__layout">
        <div class="content-page__main">
          <ArticleBody
            data={post.data}
            availableLanguages={post.data.availableLanguages || []}
            verses={post.data.verses || []}
            availableScripts={post.data.availableScripts || ["devanagari"]}
            Content={Content}
          />

          <!-- Info Accordion Sections -->
          <InfoAccordion sections={infoSections} />
        </div>

        <!-- Sidebar -->
        <div class="content-page__sidebar">
          <Sidebar currentSlug={post.slug} currentTags={post.data.tags || []} />
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  /* ===================================
     CONTENT PAGE LAYOUT
     =================================== */
  .content-page {
    padding-top: var(--nav-height);
  }

  /* Hero / Title */
  .content-page__hero {
    background: linear-gradient(
      180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 100%
    );
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-8) var(--space-4) var(--space-10);
  }

  .content-page__hero-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  /* Tags */
  .content-page__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    margin-bottom: var(--space-5);
  }

  .content-page__tag {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--gold-400);
    background: rgba(212, 160, 23, 0.1);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .content-page__tag:hover {
    background: rgba(212, 160, 23, 0.2);
    border-color: var(--border-gold-strong);
  }

  .content-page__tag--plain {
    color: var(--text-secondary);
    background: var(--surface-hover);
    border-color: var(--border-subtle);
  }

  /* Title */
  .content-page__title {
    font-size: var(--text-3xl);
    font-weight: 600;
    color: var(--gold-400);
    font-family: var(--font-devanagari);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .content-page__title-en {
    font-size: var(--text-xl);
    color: var(--text-secondary);
    font-weight: 500;
    margin-bottom: var(--space-4);
  }

  .content-page__description {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    max-width: 700px;
    margin-bottom: var(--space-5);
  }

  /* Meta row */
  .content-page__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    margin-bottom: var(--space-5);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--border-subtle);
  }

  .content-page__meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* 2-Column Layout */
  .content-page__layout {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4);
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  .content-page__main {
    min-width: 0; /* prevent overflow */
  }

  .content-page__sidebar {
    order: 1;
  }

  @media (min-width: 640px) {
    .content-page__hero {
      padding: var(--space-10) var(--space-6) var(--space-12);
    }

    .content-page__title {
      font-size: var(--text-4xl);
    }
  }

  @media (min-width: 1024px) {
    .content-page__layout {
      grid-template-columns: 1fr var(--sidebar-width);
      gap: var(--space-10);
      padding: var(--space-6) var(--space-6);
    }

    .content-page__sidebar {
      order: 0;
    }

    .content-page__title {
      font-size: var(--text-5xl);
    }

    .content-page__title-en {
      font-size: var(--text-2xl);
    }
  }

  /* Spinning icon for PDF loading */
  :global(.spin-icon) {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.spin-icon) {
      animation: none;
    }
  }
</style>
