---
import Topbar from "../components/Topbar.astro";
import Footer from "../components/Footer.astro";
import RecentCards from "../components/RecentCards.astro";
import "../styles/global.css";
import {
  SITE_TITLE,
  SITE_DESCRIPTION,
  SITE_TITLE_DEVANAGRI,
  SITE_DESCRIPTION_DEVANAGRI,
  SITE_TITLE_SEPARATOR,
  DEFAULT_ARTICLE_IMAGE,
  Tags,
  Languages,
} from "../utils/consts";
import { getPublished } from "../utils/content";
import MetadataHead from "../components/MetadataHead.astro";
import SearchModal from "../components/SearchModal.astro";

const allpages = (await getPublished("page")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const featuredPages = allpages.filter((page) => page.data.featured);
const nonFeaturedPages = allpages.filter((page) => !page.data.featured);
const pages = [...featuredPages, ...nonFeaturedPages];

const ogSiteName = `${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const ogSiteDescription = `${SITE_DESCRIPTION_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_DESCRIPTION}`;
const ogArticleImage = new URL(DEFAULT_ARTICLE_IMAGE, Astro.url);

// Count pages per tag
const tagCounts: Record<string, number> = {};
Tags.forEach((tag) => {
  tagCounts[tag] = allpages.filter((p) => p.data.tags?.includes(tag)).length;
});

const tagDescriptions: Record<string, string> = {
  stotram: "Sacred hymns of praise and devotion",
  stuti: "Devotional prayers and eulogies",
  kavach: "Protective mantras and armor prayers",
  namavali: "Collections of divine names",
  suktam: "Vedic hymns and sacred verses",
  vidhi: "Ritual procedures and worship methods",
};

const tagDescriptionsHi: Record<string, string> = {
  stotram: "स्तुति गान",
  stuti: "भक्ति प्रार्थनाएँ",
  kavach: "रक्षा मंत्र",
  namavali: "नामावली",
  suktam: "वैदिक सूक्त",
  vidhi: "पूजा विधि",
};

// YouTube discourse embeds shown in the "Sacred Discourses & Teachings" section.
const discourseVideos = [
  "5IgTqef62_0",
  "IlrIuKfMyRM",
  "j-qAWz0HA1U",
  "ArUuZUtvIr4",
  "wBCwsw8B3xM",
  "3CQHp1liclc",
  "SlwSnFMHZYw",
  "69a-mU-udqE",
];

const ldSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  publisher: {
    "@type": "Organization",
    name: ogSiteName,
    url: "https://brahmadev.in/",
    logo: {
      "@type": "ImageObject",
      url: "https://brahmadev.in/assets/images/brahma-icon.png",
      width: 60,
      height: 60,
    },
  },
  url: "https://brahmadev.in/",
  image: {
    "@type": "ImageObject",
    url: ogArticleImage,
    width: 1000,
    height: 661,
  },
  mainEntityOfPage: "https://brahmadev.in/",
  description: ogSiteDescription,
};
---

<!doctype html>
<html lang="en">
  <head>
    <MetadataHead />
    <link rel="canonical" href={new URL(Astro.url.pathname, Astro.site)} />
    <title>{ogSiteName}</title>

    <meta name="title" lang="en" content={SITE_TITLE} />
    <meta name="description" lang="en" content={SITE_DESCRIPTION} />
    <meta name="title" lang="hi" content={SITE_TITLE_DEVANAGRI} />
    <meta name="description" lang="hi" content={SITE_DESCRIPTION_DEVANAGRI} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={ogSiteName} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:description" content={ogSiteDescription} />
    <meta property="og:image" content={ogArticleImage} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={ogSiteName} />
    <meta property="twitter:description" content={ogSiteDescription} />
    <meta property="twitter:image" content={ogArticleImage} />

    <link
      rel="preload"
      as="image"
      href="/assets/cosmos-static.png"
      fetchpriority="high"
    />

    <link
      rel="preload"
      as="image"
      href="/assets/images/brahma-img-new.png"
      fetchpriority="high"
    />

    <script type="application/ld+json" set:html={JSON.stringify(ldSchema)} />
  </head>

  <body>
    <Topbar />
    <SearchModal />

    <!-- Hero Section -->
    <section class="hero" id="home">
      <video
        autoplay
        muted
        loop
        playsinline
        preload="auto"
        class="hero__video"
        aria-hidden="true"
        poster="/assets/cosmos-static.png"
      >
        <source src="/assets/cosmos.mp4" type="video/mp4" />
      </video>
      <div class="hero__overlay"></div>
      <div class="hero__glow hero__glow--left"></div>
      <div class="hero__glow hero__glow--right"></div>

      <div class="hero__content">
        <img
          src="/assets/images/brahma-img-new.png"
          alt="Lord Brahma - The Creator"
          class="hero__image"
          width="280"
          height="280"
        />

        <!-- <div class="hero__text">
          <h1 class="hero__greeting" lang="sa">श्री ब्रह्मणे नमः</h1>
          <p class="hero__greeting-en">Shrī Brahmaṇe Namaḥ</p>
        </div> -->

        <div class="hero__card">
          <h2 class="hero__title" lang="sa">ॐ ब्रह्मणे नमः</h2>
          <h3 class="hero__subtitle">Ōṁ Brahmaṇe Namaḥ</h3>
          <p class="hero__desc">
            The most comprehensive digital repository of authentic Vedic and
            Puranic knowledge dedicated to
            <strong>Lord Brahma</strong> - featuring sacred stotras, mantras, stutis,
            kavach, and scriptural wisdom.
          </p>
        </div>

        <div class="hero__stats">
          <div class="hero__stat">
            <span class="hero__stat-number">{allpages.length}+</span>
            <span class="hero__stat-label">Sacred Texts</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-number">{Languages.length}</span>
            <span class="hero__stat-label">Languages</span>
          </div>
          <div class="hero__stat-divider"></div>
          <div class="hero__stat">
            <span class="hero__stat-number">{Tags.length}</span>
            <span class="hero__stat-label">Categories</span>
          </div>
        </div>

        <div class="hero__cta">
          <a href="/tags" class="hero__cta-primary">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"
              ></path></svg
            >
            Explore Sacred Texts
          </a>
          <a href="#introduction" class="hero__cta-secondary">
            Learn More
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg
            >
          </a>
        </div>
      </div>
    </section>

    <main id="main-content">
      <!-- Features Section -->
      <section class="hp-section" id="features">
        <div class="hp-container">
          <div class="section-header fade-in-on-scroll">
            <span class="section-label">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"
                ></path></svg
              >
              Features
            </span>
            <h2 class="section-title">
              Sacred Knowledge <span class="highlight">Repository</span>
            </h2>
            <p class="section-subtitle">पवित्र ज्ञान भंडार</p>
          </div>
          <div class="features-grid">
            <div class="glass-card feature-card fade-in-on-scroll">
              <div class="feature-card__icon">📜</div>
              <h3 class="feature-card__title">Authentic Sources</h3>
              <p class="feature-card__desc">
                All content sourced from original Vedas, Puranas, and Itihasas
                with proper scriptural references.
              </p>
              <ul class="feature-card__list">
                <li>Rigveda & Other Vedic Texts</li>
                <li>18 Major Puranas</li>
                <li>Upanishads & Tantras</li>
              </ul>
            </div>
            <div class="glass-card feature-card fade-in-on-scroll">
              <div class="feature-card__icon">🔤</div>
              <h3 class="feature-card__title">Multi-Script Access</h3>
              <p class="feature-card__desc">
                Sanskrit integrity preserved across multiple scripts and
                translations.
              </p>
              <ul class="feature-card__list">
                <li>Devanagari Script</li>
                <li>IAST Transliteration</li>
                <li>English, Hindi, and Marathi Translations</li>
              </ul>
            </div>
            <div class="glass-card feature-card fade-in-on-scroll">
              <div class="feature-card__icon">📿</div>
              <h3 class="feature-card__title">Significance & Practice</h3>
              <p class="feature-card__desc">
                Every stotra comes with its meaning, benefits, and step-by-step
                recitation guidance.
              </p>
              <ul class="feature-card__list">
                <li>महत्त्व (Significance)</li>
                <li>लाभ (Benefits)</li>
                <li>पाठ विधि (Recitation Vidhi)</li>
              </ul>
            </div>
          </div>
        </div>
      </section>

      <!-- Categories Section -->
      <section class="hp-section hp-section--alt">
        <div class="hp-container">
          <div class="section-header fade-in-on-scroll">
            <span class="section-label">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M12.586 2.586A2 2 0 0 0 11.172 2H4a2 2 0 0 0-2 2v7.172a2 2 0 0 0 .586 1.414l8.704 8.704a2.426 2.426 0 0 0 3.42 0l6.58-6.58a2.426 2.426 0 0 0 0-3.42z"
                ></path><circle cx="7.5" cy="7.5" r=".5" fill="currentColor"
                ></circle></svg
              >
              Categories
            </span>
            <h2 class="section-title">
              Sacred <span class="highlight">Collections</span>
            </h2>
            <p class="section-subtitle">पवित्र संग्रह</p>
          </div>
          <div class="categories-grid">
            {
              Tags.map((tag, i) => (
                <a
                  href={`/tags/${tag}`}
                  class="category-card glass-card fade-in-on-scroll"
                  style={`--reveal-delay: ${i * 60}ms`}
                >
                  <div class="category-card__header">
                    <h3 class="category-card__title">
                      {tag.charAt(0).toUpperCase() + tag.slice(1)}
                    </h3>
                    <span class="category-card__count">{tagCounts[tag]}</span>
                  </div>
                  <p class="category-card__subtitle" lang="hi">
                    {tagDescriptionsHi[tag]}
                  </p>
                  <p class="category-card__desc">{tagDescriptions[tag]}</p>
                  <span class="category-card__arrow">
                    <svg
                      xmlns="http://www.w3.org/2000/svg"
                      width="20"
                      height="20"
                      viewBox="0 0 24 24"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      aria-hidden="true"
                    >
                      <>
                        <path d="M5 12h14" />
                        <path d="m12 5 7 7-7 7" />
                      </>
                    </svg>
                  </span>
                </a>
              ))
            }
          </div>
        </div>
      </section>

      <!-- Introduction -->
      <section class="hp-section" id="introduction">
        <div class="hp-container hp-container--narrow">
          <div class="section-header fade-in-on-scroll">
            <span class="section-label">Introduction</span>
            <h2 class="section-title">
              Who is <span class="highlight">Lord Brahma</span>?
            </h2>
            <p class="section-subtitle">ब्रह्मा कौन हैं?</p>
          </div>
          <div class="prose-content">
            <p>
              <strong>Brahma</strong> is Srishti-kartā, the Creator - the first of
              the Trimurti, self-born as <em>Hiranyagarbha</em>, the Golden Womb
              of the Rigveda, and revered in the Vedas and Puranas as Prajāpati,
              the progenitor from whom the four Vedas, the sages, and all
              creation arose.
            </p>
            <p>
              Across the Ramayana, Mahabharata, and the Puranas he is invoked as <em
                >Parameṣṭhī</em
              > and <em>Jagatkartā</em> - approached by the Devas themselves in every
              hour of cosmic crisis, and revered by the Saptarishis, the great sages
              born of his own mind, as the Supreme Creator long before later traditions
              reshaped his place in devotion. This site gathers his stotras, mantras,
              and scriptural references to present that legacy in its own words.
            </p>
          </div>
        </div>
      </section>

      <!-- Is Brahma Personified Brahman -->
      <section class="hp-section hp-section--alt">
        <div class="hp-container hp-container--narrow">
          <div class="content-card fade-in-on-scroll">
            <h2 class="content-card__title">
              Is Brahma the Personified Brahman?
            </h2>
            <div class="prose-content">
              <p>
                Scriptures provide strong evidence that <strong
                  >Brahma is indeed the personified Brahman</strong
                >. The <em>Taittiriya Upanishad</em> defines Brahman as:
              </p>
              <blockquote class="scripture-quote">
                <p class="scripture-quote__text" lang="sa">
                  "यतो वा इमानि भूतानि जायन्ते । येन जातानि जीवन्ति ।
                  यत्प्रयन्त्यभिसंविशन्ति । तद्विजिज्ञासस्व । तद्ब्रह्मेति ॥"
                </p>
                <footer class="scripture-quote__source">
                  <strong>Taittiriya Upanishad 3.1.3:</strong> "Whence indeed these
                  beings are born; whereby, when born, they live; wherein, when departing,
                  they enter - That seek thou to know; That is Brahman."
                </footer>
              </blockquote>
              <p>
                Thus, Brahman is the <strong
                  >creator, sustainer, and the ultimate destination</strong
                > of all beings. The <em>Mundaka Upanishad</em> explicitly describes
                Brahma in these exact terms:
              </p>
              <blockquote class="scripture-quote">
                <p class="scripture-quote__text" lang="sa">
                  "ब्रह्मा देवानां प्रथमः संबभूव विश्वस्यकर्ता भुवनस्य गोप्ता।"
                </p>
                <footer class="scripture-quote__source">
                  <strong>Mundaka Upanishad 1.1.1:</strong> "Brahma was the first
                  among the Devas, the creator of the universe, and the protector
                  of the world."
                </footer>
              </blockquote>
            </div>

            <div class="evidence-grid">
              <div class="evidence-card">
                <h4 class="evidence-card__title">Mahabharata Testimony</h4>
                <p class="evidence-card__desc">
                  In the Adi Parva (1.32.20), Sesha addresses Brahma as:
                </p>
                <ul class="evidence-card__list">
                  <li>
                    <strong lang="sa">प्रजापति</strong> (Prajāpati) - Lord of all
                    beings
                  </li>
                  <li>
                    <strong lang="sa">महीपति</strong> (Mahīpati) - Lord of the earth
                  </li>
                  <li>
                    <strong lang="sa">भूतपति</strong> (Bhūtapati) - Lord of all creatures
                  </li>
                  <li>
                    <strong lang="sa">जगत्पति</strong> (Jagatpati) - Lord of the universe
                  </li>
                </ul>
              </div>
              <div class="evidence-card">
                <h4 class="evidence-card__title">Ramayana Confirmation</h4>
                <p class="evidence-card__desc">
                  Valmiki Ramayana (2.22.11) praises Brahma as:
                </p>
                <ul class="evidence-card__list">
                  <li>
                    <strong lang="sa">सर्वलोकप्रभु</strong> (Sarvalokaprabhu) - Lord
                    of all worlds
                  </li>
                  <li>
                    <strong lang="sa">भूतभर्ता</strong> (Bhūtabhartā) - Supporter
                    of all beings
                  </li>
                  <li>
                    <strong lang="sa">परमीशान</strong> (Paramīśāna) - The Supreme
                    Lord
                  </li>
                </ul>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- Sacred Discourses & Teachings -->
      <section class="hp-section">
        <div class="hp-container">
          <div class="video-section__card fade-in-on-scroll">
            <div class="section-header">
              <span class="section-label">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="16"
                  height="16"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  ><path d="m10 8 6 4-6 4V8z"></path><rect
                    width="20"
                    height="16"
                    x="2"
                    y="4"
                    rx="2"></rect></svg
                >
                Discourses
              </span>
              <h2 class="section-title">
                Sacred Discourses & <span class="highlight">Teachings</span>
              </h2>
              <p class="section-subtitle">पवित्र प्रवचन एवं उपदेश</p>
            </div>
            <div class="video-grid">
              {
                discourseVideos.map((id) => (
                  <div class="video-card">
                    <div class="video-card__frame">
                      <iframe
                        src={`https://www.youtube.com/embed/${id}`}
                        title="Sacred Teaching"
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                        allowfullscreen
                      />
                    </div>
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </section>

      <!-- Symbolism -->
      <section class="hp-section">
        <div class="hp-container">
          <div class="section-header fade-in-on-scroll">
            <span class="section-label">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                ><path
                  d="M11.017 2.814a1 1 0 0 1 1.966 0l1.051 5.558a2 2 0 0 0 1.594 1.594l5.558 1.051a1 1 0 0 1 0 1.966l-5.558 1.051a2 2 0 0 0-1.594 1.594l-1.051 5.558a1 1 0 0 1-1.966 0l-1.051-5.558a2 2 0 0 0-1.594-1.594l-5.558-1.051a1 1 0 0 1 0-1.966l5.558-1.051a2 2 0 0 0 1.594-1.594z"
                ></path></svg
              >
              Iconography
            </span>
            <h2 class="section-title">
              Symbolism & <span class="highlight">Iconography</span>
            </h2>
            <p class="section-subtitle">प्रतीकवाद और प्रतिमाशास्त्र</p>
          </div>
          <div class="symbolism-grid">
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">🕉️</div>
              <h3 class="symbolism-card__title" lang="hi">
                चतुर्मुख (Chaturmukha)
              </h3>
              <p class="symbolism-card__desc">
                Four faces represent the Panch Mahabhutas: Fire, Air, Water,
                Sky, and Earth. Also symbolize four Vedas and four directions.
              </p>
            </div>
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">🙏</div>
              <h3 class="symbolism-card__title" lang="hi">
                चतुर्भुज (Chaturbhuj)
              </h3>
              <p class="symbolism-card__desc">
                Four arms holding the Vedas (knowledge), Kamaṇḍalu (cosmic
                waters), Rudrākṣa mālā (time), and Padma (lotus).
              </p>
            </div>
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">🦢</div>
              <h3 class="symbolism-card__title" lang="hi">
                हंसवाहन (Haṃsavāhana)
              </h3>
              <p class="symbolism-card__desc">
                Swan (Haṃsa) symbolizes supreme wisdom, discrimination between
                real and unreal, and transcendent consciousness.
              </p>
            </div>
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">✨</div>
              <h3 class="symbolism-card__title" lang="hi">
                स्वर्णवर्ण (Svarṇavarṇa)
              </h3>
              <p class="symbolism-card__desc">
                Golden complexion represents the luminous Hiraṇyagarbha - the
                radiant, imperishable nature of supreme consciousness.
              </p>
            </div>
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">🪷</div>
              <h3 class="symbolism-card__title" lang="hi">
                पद्मासन (Padmāsana)
              </h3>
              <p class="symbolism-card__desc">
                Lotus seat symbolizes purity emerging from cosmic waters,
                creation arising from consciousness untouched by ignorance.
              </p>
            </div>
            <div class="glass-card symbolism-card fade-in-on-scroll">
              <div class="symbolism-card__icon">👴</div>
              <h3 class="symbolism-card__title" lang="hi">पितामह (Pitāmaha)</h3>
              <p class="symbolism-card__desc">
                Matured appearance symbolizes ancient wisdom, eternal existence,
                and his status as the grandfather of all creation.
              </p>
            </div>
          </div>
        </div>
      </section>

      <!-- Recent Texts -->
      <section class="hp-section hp-section--alt">
        <div class="hp-container">
          <div class="section-header fade-in-on-scroll">
            <span class="section-label">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="16"
                height="16"
                viewBox="0 0 24 24"
                fill="none"
