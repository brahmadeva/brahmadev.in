---
import Topbar from "../components/Topbar.astro";
import Footer from "../components/Footer.astro";

import {
  SITE_TITLE_SEPARATOR,
  SITE_TITLE,
  SITE_TITLE_DEVANAGRI,
} from "../utils/consts";
import MetadataHead from "../components/MetadataHead.astro";
import SearchModal from "../components/SearchModal.astro";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const ogSiteName = `${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;

const pageName = `404 Page Not Found ${SITE_TITLE_SEPARATOR} ${ogSiteName}`;
---

<html lang="en">
  <head>
    <MetadataHead />

    <link rel="canonical" href={canonicalURL} />
    <title>{pageName}</title>
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageName} />
    <meta property="og:site_name" content={ogSiteName} />
  </head>

  <body>
    <Topbar />
    <SearchModal />

    <main id="main-content" class="notfound">
      <div class="notfound__glow"></div>
      <div class="notfound__card">
        <span class="notfound__code">404</span>
        <h1 class="notfound__title">Page Not Found</h1>
        <p class="notfound__subtitle" lang="hi">यह पृष्ठ उपलब्ध नहीं है</p>
        <p class="notfound__desc">
          The sacred text or page you are seeking does not exist or may have been moved.
        </p>
        <div class="notfound__actions">
          <a href="/" class="notfound__btn notfound__btn--primary">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
            Return Home
          </a>
          <a href="/tags" class="notfound__btn notfound__btn--secondary">
            Browse Scriptures
          </a>
        </div>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .notfound {
    position: relative;
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: calc(var(--nav-height) + var(--space-12)) var(--space-4) var(--space-16);
    overflow: hidden;
  }

  .notfound__glow {
    position: absolute;
    top: 30%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 500px;
    height: 500px;
    max-width: 90vw;
    border-radius: var(--radius-full);
    background: var(--gold-500);
    filter: blur(140px);
    opacity: 0.12;
    pointer-events: none;
  }

  .notfound__card {
    position: relative;
    text-align: center;
    max-width: 520px;
    background: var(--bg-card);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-2xl);
    padding: var(--space-12) var(--space-8);
    box-shadow: var(--shadow-xl);
  }

  .notfound__code {
    display: block;
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    background: linear-gradient(135deg, var(--gold-400), var(--saffron-500));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    margin-bottom: var(--space-4);
  }

  .notfound__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-1);
  }

  .notfound__subtitle {
    font-size: var(--text-base);
    color: var(--gold-400);
    font-family: var(--font-devanagari);
    margin-bottom: var(--space-4);
  }

  .notfound__desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
  }

  .notfound__actions {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    align-items: center;
  }

  .notfound__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-6);
    font-size: var(--text-sm);
    font-weight: 600;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-base);
  }

  .notfound__btn--primary {
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    color: #fff;
    box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
  }

  .notfound__btn--primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
  }

  .notfound__btn--secondary {
    background: transparent;
    color: var(--gold-400);
    border: 1px solid var(--border-gold);
  }

  .notfound__btn--secondary:hover {
    border-color: var(--border-gold-strong);
    background: var(--surface-gold-subtle);
  }

  @media (min-width: 480px) {
    .notfound__actions {
      flex-direction: row;
      justify-content: center;
    }
    .notfound__code {
      font-size: 6.5rem;
    }
  }
</style>
