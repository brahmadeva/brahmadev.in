---
import { type CollectionEntry } from "astro:content";
import { getPublished } from "../../utils/content";
import Topbar from "../../components/Topbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import MetadataHead from "../../components/MetadataHead.astro";
import SearchModal from "../../components/SearchModal.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import {
  SITE_TITLE_SEPARATOR,
  SITE_TITLE,
  SITE_TITLE_DEVANAGRI,
  DEFAULT_ARTICLE_IMAGE,
} from "../../utils/consts";

export async function getStaticPaths() {
  const articles = await getPublished("articles");
  return articles.map((article) => ({
    params: { slug: article.slug },
    props: article,
  }));
}

type Props = CollectionEntry<"articles">;

const article = Astro.props;
const { Content } = await article.render();

const {
  title,
  titleDevanagri,
  titleEnglish,
  description,
  author,
  category,
  pubDate,
  heroImage,
} = article.data;

const displayTitle = title || titleEnglish || titleDevanagri || article.slug;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogSiteName = `${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const pageTitle = `${displayTitle} ${SITE_TITLE_SEPARATOR} ${ogSiteName}`;
const finalHeroImage = new URL(heroImage || DEFAULT_ARTICLE_IMAGE, Astro.url);

// Reading time estimate from the raw markdown body
const words = article.body ? article.body.trim().split(/\s+/).filter(Boolean).length : 0;
const readingTime = Math.max(1, Math.round(words / 200));

// Related articles (same category preferred), excluding the current one
const allArticles = (await getPublished("articles"))
  .filter((a) => a.slug !== article.slug)
  .sort((a, b) => {
    const da = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
    const db = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
    return db - da;
  });
const related = [
  ...allArticles.filter((a) => category && a.data.category === category),
  ...allArticles.filter((a) => !category || a.data.category !== category),
].slice(0, 3);

const relatedTitle = (data: Record<string, any>, slug: string) =>
  data.title || data.titleEnglish || data.titleDevanagri || slug;

const ldSchema = {
  "@context": "https://schema.org",
  "@type": "Article",
  publisher: {
    "@type": "Organization",
    name: ogSiteName,
    url: "https://brahmadev.in/",
    logo: {
      "@type": "ImageObject",
      url: "https://brahmadev.in/assets/images/brahma-icon.png",
      width: 60,
      height: 60,
    },
  },
  headline: displayTitle,
  ...(author ? { author: { "@type": "Person", name: author } } : {}),
  ...(pubDate ? { datePublished: pubDate } : {}),
  description: description,
  image: finalHeroImage,
  url: Astro.url,
  mainEntityOfPage: Astro.url,
};
---

<html lang="en">
  <head>
    <MetadataHead />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageTitle}</title>

    <meta name="title" content={displayTitle} />
    <meta name="description" content={description} />

    <meta property="og:type" content="article" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={displayTitle} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={finalHeroImage} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:title" content={displayTitle} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={finalHeroImage} />

    <script type="application/ld+json" set:html={JSON.stringify(ldSchema)}></script>
  </head>

  <body>
    <Topbar />
    <SearchModal />

    <main id="main-content" class="article">
      <!-- Hero -->
      <div class="article__hero">
        <div class="article__hero-inner">
          <Breadcrumb items={[
            { label: "Home", href: "/" },
            { label: "Articles", href: "/articles" },
            { label: displayTitle },
          ]} />

          {category && <span class="article__category">{category}</span>}

          <h1 class="article__title">{displayTitle}</h1>
          {titleDevanagri && displayTitle !== titleDevanagri && (
            <p class="article__title-hi" lang="hi">{titleDevanagri}</p>
          )}
          {description && <p class="article__lede">{description}</p>}

          <div class="article__meta">
            {author && (
              <span class="article__meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
                {author}
              </span>
            )}
            {pubDate && (
              <span class="article__meta-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"></rect><line x1="16" x2="16" y1="2" y2="6"></line><line x1="8" x2="8" y1="2" y2="6"></line><line x1="3" x2="21" y1="10" y2="10"></line></svg>
                <FormattedDate date={pubDate} />
              </span>
            )}
            <span class="article__meta-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
              {readingTime} min read
            </span>
          </div>
        </div>
      </div>

      <!-- Hero image -->
      <div class="article__banner-wrap">
        <img
          src={heroImage || DEFAULT_ARTICLE_IMAGE}
          alt=""
          width="1200"
          height="630"
          loading="eager"
          decoding="async"
          class="article__banner"
        />
      </div>

      <!-- Body -->
      <article class="article__body article-prose">
        <Content />
      </article>

      <!-- Related -->
      {related.length > 0 && (
        <section class="article__related">
          <h2 class="article__related-title">Continue Reading</h2>
          <div class="article__related-grid">
            {related.map((r) => (
              <a href={`/articles/${r.slug}/`} class="article__related-card">
                {r.data.category && <span class="article__related-category">{r.data.category}</span>}
                <h3 class="article__related-heading">{relatedTitle(r.data, r.slug)}</h3>
                {r.data.description && <p class="article__related-desc">{r.data.description}</p>}
              </a>
            ))}
          </div>
        </section>
      )}

      <div class="article__back">
        <a href="/articles" class="article__back-link">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg>
          Back to all articles
        </a>
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .article {
    padding-top: var(--nav-height);
  }

  /* Hero */
  .article__hero {
    background: linear-gradient(180deg, var(--bg-primary) 0%, var(--bg-secondary) 100%);
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-8) var(--space-4) var(--space-10);
  }

  .article__hero-inner {
    max-width: var(--article-max-width);
    margin: 0 auto;
  }

  .article__category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold-400);
    background: var(--surface-gold);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    padding: var(--space-1) var(--space-3);
    margin-bottom: var(--space-4);
  }

  .article__title {
    font-size: var(--text-3xl);
    font-weight: 800;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-3);
  }

  .article__title-hi {
    font-size: var(--text-xl);
    color: var(--gold-400);
    font-family: var(--font-devanagari);
    margin-bottom: var(--space-3);
  }

  .article__lede {
    font-size: var(--text-lg);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-5);
  }

  .article__meta {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    align-items: center;
    padding-top: var(--space-4);
    border-top: 1px solid var(--border-subtle);
  }

  .article__meta-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }

  /* Banner image */
  .article__banner-wrap {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-8) var(--space-4) 0;
  }

  .article__banner {
    width: 100%;
    height: auto;
    max-height: 460px;
    object-fit: cover;
    border-radius: var(--radius-xl);
    border: 1px solid var(--border-subtle);
    box-shadow: var(--shadow-lg);
  }

  /* Body / prose */
  .article__body {
    max-width: var(--article-max-width);
    margin: 0 auto;
    padding: var(--space-10) var(--space-4);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    color: var(--text-secondary);
  }

  .article-prose :global(h2) {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin: var(--space-10) 0 var(--space-4);
  }

  .article-prose :global(h3) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin: var(--space-8) 0 var(--space-3);
  }

  .article-prose :global(h2)::before {
    content: "";
    display: block;
    width: 48px;
    height: 3px;
    background: linear-gradient(90deg, var(--gold-500), var(--saffron-500));
    border-radius: var(--radius-full);
    margin-bottom: var(--space-4);
  }

  .article-prose :global(p) {
    margin-bottom: var(--space-5);
  }

  .article-prose :global(a) {
    color: var(--gold-400);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .article-prose :global(strong) {
    color: var(--text-primary);
    font-weight: 700;
  }

  .article-prose :global(em) {
    color: var(--text-primary);
  }

  .article-prose :global(ul),
  .article-prose :global(ol) {
    margin: 0 0 var(--space-5);
    padding-left: var(--space-6);
  }

  .article-prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .article-prose :global(blockquote) {
    border-left: 4px solid var(--gold-400);
    background: var(--surface-gold-subtle);
    padding: var(--space-4) var(--space-5);
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
    margin: var(--space-6) 0;
    color: var(--text-secondary);
    font-style: italic;
  }

  .article-prose :global(hr) {
    border: none;
    border-top: 1px solid var(--border-subtle);
    margin: var(--space-8) 0;
  }

  .article-prose :global(img) {
    max-width: 100%;
    height: auto;
    border-radius: var(--radius-lg);
  }

  .article-prose :global(code) {
    background: var(--surface-hover);
    padding: 2px 6px;
    border-radius: var(--radius-sm);
    font-size: 0.9em;
  }

  /* Related */
  .article__related {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-10) var(--space-4);
    border-top: 1px solid var(--border-subtle);
  }

  .article__related-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-6);
  }

  .article__related-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .article__related-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    padding: var(--space-5);
    text-decoration: none;
    transition: transform var(--transition-base), border-color var(--transition-base), box-shadow var(--transition-base);
  }

  .article__related-card:hover {
    border-color: var(--border-gold);
    box-shadow: var(--shadow-gold);
    transform: translateY(-3px);
  }

  .article__related-category {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold-400);
    margin-bottom: var(--space-2);
  }

  .article__related-heading {
    font-size: var(--text-base);
    font-weight: 700;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .article__related-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    line-height: var(--leading-normal);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Back link */
  .article__back {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: 0 var(--space-4) var(--space-16);
  }

  .article__back-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .article__back-link:hover {
    color: var(--gold-400);
  }

  @media (min-width: 640px) {
    .article__title {
      font-size: var(--text-4xl);
    }
    .article__related-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article__title {
      font-size: var(--text-5xl);
    }
  }
</style>
