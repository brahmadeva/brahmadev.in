---
import Topbar from "../../components/Topbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumb from "../../components/Breadcrumb.astro";
import MetadataHead from "../../components/MetadataHead.astro";
import SearchModal from "../../components/SearchModal.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import {
  SITE_TITLE_SEPARATOR,
  SITE_TITLE,
  SITE_TITLE_DEVANAGRI,
  SITE_DESCRIPTION,
  DEFAULT_ARTICLE_IMAGE,
} from "../../utils/consts";
import { getPublished } from "../../utils/content";

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogSiteName = `${SITE_TITLE_DEVANAGRI} ${SITE_TITLE_SEPARATOR} ${SITE_TITLE}`;
const pageName = `Articles ${SITE_TITLE_SEPARATOR} ${ogSiteName}`;
const pageDescription =
  "Scholarly articles exploring the history, philosophy, and scriptural evidence surrounding Lord Brahma.";

const articles = (await getPublished("articles")).sort((a, b) => {
  const da = a.data.pubDate ? a.data.pubDate.valueOf() : 0;
  const db = b.data.pubDate ? b.data.pubDate.valueOf() : 0;
  return db - da;
});

// Featured first, then the rest (already date-sorted within each group)
const featured = articles.filter((a) => a.data.featured);
const rest = articles.filter((a) => !a.data.featured);
const ordered = [...featured, ...rest];

const displayTitle = (data: Record<string, any>, slug: string) =>
  data.title || data.titleEnglish || data.titleDevanagri || slug;

const ldSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  publisher: {
    "@type": "Organization",
    name: ogSiteName,
    url: "https://brahmadev.in/",
    logo: {
      "@type": "ImageObject",
      url: "https://brahmadev.in/assets/images/brahma-icon.png",
      width: 60,
      height: 60,
    },
  },
  url: Astro.url,
  name: pageName,
  description: pageDescription,
  mainEntityOfPage: Astro.url,
};
---

<html lang="en">
  <head>
    <MetadataHead />
    <link rel="canonical" href={canonicalURL} />
    <title>{pageName}</title>

    <meta name="title" content={pageName} />
    <meta name="description" content={pageDescription} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={pageName} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:description" content={pageDescription} />

    <script type="application/ld+json" set:html={JSON.stringify(ldSchema)} />
  </head>

  <body>
    <Topbar />
    <SearchModal />

    <main id="main-content" class="articles-page">
      <!-- Hero -->
      <div class="articles-page__hero">
        <div class="articles-page__hero-inner">
          <Breadcrumb
            items={[{ label: "Home", href: "/" }, { label: "Articles" }]}
          />
          <span class="section-label">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              ><path
                d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"
              ></path></svg
            >
            Articles
          </span>
          <h1 class="articles-page__title">
            Scholarly <span class="highlight">Articles</span>
          </h1>
          <p class="articles-page__subtitle" lang="hi">विद्वत्तापूर्ण लेख</p>
          <p class="articles-page__desc">{pageDescription}</p>
        </div>
      </div>

      <!-- Grid -->
      <div class="articles-page__content">
        {
          ordered.length > 0 ? (
            <div class="article-grid">
              {ordered.map((article, i) => (
                <a
                  href={`/articles/${article.slug}/`}
                  class="article-card fade-in-on-scroll"
                  style={`--reveal-delay: ${Math.min(i, 8) * 60}ms`}
                >
                  <div class="article-card__media">
                    <img
                      src={article.data.heroImage || DEFAULT_ARTICLE_IMAGE}
                      alt=""
                      width="400"
                      height="225"
                      loading="lazy"
                      decoding="async"
                      class="article-card__img"
                    />
                    {article.data.featured && (
                      <span class="article-card__badge">Featured</span>
                    )}
                  </div>
                  <div class="article-card__body">
                    {article.data.category && (
                      <span class="article-card__category">
                        {article.data.category}
                      </span>
                    )}
                    <h2 class="article-card__title">
                      {displayTitle(article.data, article.slug)}
                    </h2>
                    {article.data.description && (
                      <p class="article-card__desc">
                        {article.data.description}
                      </p>
                    )}
                  </div>
                  <div class="article-card__footer">
                    {article.data.author && (
                      <span class="article-card__author">
                        {article.data.author}
                      </span>
                    )}
                    {article.data.pubDate && (
                      <FormattedDate date={article.data.pubDate} />
                    )}
                  </div>
                </a>
              ))}
            </div>
          ) : (
            <div class="articles-page__empty">
              <div class="articles-page__empty-icon">📖</div>
              <h2 class="articles-page__empty-title">No articles yet</h2>
              <p class="articles-page__empty-desc">Please check back soon.</p>
              <a href="/tags" class="articles-page__empty-cta">
                Browse Sacred Texts
              </a>
            </div>
          )
        }
      </div>
    </main>

    <Footer />
  </body>
</html>

<style>
  .articles-page {
    padding-top: var(--nav-height);
  }

  /* Hero */
  .articles-page__hero {
    background: linear-gradient(
      180deg,
      var(--bg-primary) 0%,
      var(--bg-secondary) 100%
    );
    border-bottom: 1px solid var(--border-subtle);
    padding: var(--space-8) var(--space-4) var(--space-10);
  }

  .articles-page__hero-inner {
    max-width: var(--content-max-width);
    margin: 0 auto;
  }

  .articles-page__title {
    font-size: var(--text-3xl);
    font-weight: 700;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-1);
  }

  .articles-page__title .highlight {
    color: var(--gold-400);
  }

  .articles-page__subtitle {
    font-size: var(--text-lg);
    color: var(--gold-400);
    font-family: var(--font-devanagari);
    margin-bottom: var(--space-3);
  }

  .articles-page__desc {
    font-size: var(--text-base);
    color: var(--text-muted);
    max-width: 640px;
  }

  /* Content */
  .articles-page__content {
    max-width: var(--content-max-width);
    margin: 0 auto;
    padding: var(--space-10) var(--space-4);
  }

  .article-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .article-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-lg);
    text-decoration: none;
    overflow: hidden;
    transition:
      transform var(--transition-base),
      border-color var(--transition-base),
      box-shadow var(--transition-base);
  }

  .article-card:hover {
    border-color: var(--border-gold);
    box-shadow: var(--shadow-gold);
    transform: translateY(-3px);
  }

  .article-card__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--bg-tertiary);
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--transition-slow);
  }

  .article-card:hover .article-card__img {
    transform: scale(1.04);
  }

  .article-card__badge {
    position: absolute;
    top: var(--space-3);
    left: var(--space-3);
    font-size: var(--text-xs);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: #fff;
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    padding: 2px 10px;
    border-radius: var(--radius-full);
    box-shadow: var(--shadow-md);
  }

  .article-card__body {
    padding: var(--space-5);
    flex: 1;
  }

  .article-card__category {
    display: inline-block;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--gold-400);
    background: var(--surface-gold);
    border: 1px solid var(--border-gold);
    border-radius: var(--radius-full);
    padding: 2px 10px;
    margin-bottom: var(--space-3);
  }

  .article-card__title {
    font-size: var(--text-lg);
    font-weight: 700;
    color: var(--text-primary);
    line-height: var(--leading-tight);
    margin-bottom: var(--space-2);
  }

  .article-card__desc {
    font-size: var(--text-sm);
    color: var(--text-secondary);
    line-height: var(--leading-relaxed);
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .article-card__footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-5);
    border-top: 1px solid var(--border-subtle);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }

  .article-card__author {
    font-weight: 600;
    color: var(--text-secondary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Empty state */
  .articles-page__empty {
    text-align: center;
    padding: var(--space-16) var(--space-6);
    background: var(--bg-card);
    border: 1px solid var(--border-subtle);
    border-radius: var(--radius-xl);
    max-width: 500px;
    margin: 0 auto;
  }

  .articles-page__empty-icon {
    font-size: 3rem;
    margin-bottom: var(--space-4);
  }

  .articles-page__empty-title {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: var(--space-3);
  }

  .articles-page__empty-desc {
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
  }

  .articles-page__empty-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-4) var(--space-8);
    background: linear-gradient(135deg, var(--saffron-500), var(--saffron-600));
    color: white;
    font-weight: 700;
    font-size: var(--text-base);
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: all var(--transition-base);
    box-shadow: 0 4px 15px rgba(255, 107, 53, 0.3);
  }

  .articles-page__empty-cta:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(255, 107, 53, 0.4);
  }

  @media (min-width: 640px) {
    .articles-page__title {
      font-size: var(--text-4xl);
    }
    .article-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 1024px) {
    .article-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
</style>
